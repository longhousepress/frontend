---
import { Image } from 'astro:assets';

/*
  BookCard.astro

  Props:
    - title: string
    - author: string
    - price: string (optional)
    - img: ImageMetadata | string - optimized image from src/assets or URL
    - href: string (optional) - if provided, the whole card becomes a link
    - description: string (optional) - short description shown on hover
    - categories: string[] (optional) - genres/categories shown on hover
    - sizeClasses: string (optional) - Tailwind width classes to control sizing

  Usage:
    <BookCard
      title="1984"
      author="George Orwell"
      price="£4.99"
      img={cover080}
      href="/books/1984"
      description="A dystopian novel..."
      categories={["Fiction", "Dystopian"]}
      sizeClasses="w-36 sm:w-44 md:w-52 lg:w-60"
    />
*/
const {
  title = "Book Title",
  author = "Author Name",
  price = "",
  img,
  href = null,
  description = "",
  categories = [],
  sizeClasses = "w-full",
  original = false,
} = Astro.props;

// Determine if img is an imported asset or a string path
const isImportedAsset = img && typeof img === 'object' && 'src' in img;

// Always use webp format for optimized images
const imageFormat = isImportedAsset ? 'webp' : undefined;
---
<article
  class={`group card bg-base-100 ${sizeClasses} shadow-sm hover:shadow-md transition-shadow duration-150 relative rounded-lg border-2 border-base-300`}
  style="box-shadow: 0 15px 35px -5px rgba(0, 0, 0, 0.2), 0 10px 15px -8px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(0, 0, 0, 0.05);"
  aria-label={`Book: ${title} by ${author}`}
>
  <a
    href={href || undefined}
    data-astro-prefetch
    class={href ? "block focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-lg" : "block rounded-lg pointer-events-none"}
    aria-label={href ? `View details for ${title} by ${author}` : undefined}
  >
    <figure style="aspect-ratio: 6 / 9;" class="w-full overflow-hidden rounded-t-md relative">
      {isImportedAsset ? (
        <Image
          src={img}
          alt={`Cover of ${title} by ${author}`}
          widths={[200, 300, 400, 600]}
          sizes="(max-width: 640px) 144px, (max-width: 768px) 176px, (max-width: 1024px) 208px, 240px"
          format={imageFormat}
          class="w-full h-full object-cover transition-all duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <img
          src={img}
          alt={`Cover of ${title} by ${author}`}
          class="w-full h-full object-cover transition-all duration-300 group-hover:scale-105"
          loading="lazy"
        />
      )}
      
      {/* Longhouse Original Ribbon */}
      {original && (
        <div class="absolute top-0 left-0 right-0 bg-primary/90 text-primary-content text-[10px] font-semibold tracking-wide text-center py-1 z-10 uppercase">
          Longhouse original
        </div>
      )}

      {/* Hover Overlay */}
      {(description || categories.length > 0) && (
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/85 transition-all duration-300 flex items-center justify-center p-4 opacity-0 group-hover:opacity-100">
          <div class="text-center text-white flex flex-col items-center justify-center h-full">
            {description && (
              <p class="text-xs sm:text-sm leading-relaxed mb-3 line-clamp-6">
                {description}
              </p>
            )}
            {description && categories.length > 0 && (
              <div class="w-16 h-px bg-white/40 mb-3"></div>
            )}
            {categories.length > 0 && (
              <p class="text-xs opacity-80">
                {categories.join(' • ')}
              </p>
            )}
          </div>
        </div>
      )}
    </figure>

    <div class="card-body pb-12" style="height: 140px;">
      <h3 class="text-sm opacity-70" style="color: var(--color-base-content);">{author}</h3>
      <h2 class="card-title text-base leading-tight text-base-content">{title}</h2>
    </div>

    {price && (
      <span class="absolute bottom-3 right-3 text-sm font-medium text-primary" aria-hidden="true">
        {price}
      </span>
    )}
  </a>
</article>

<style>
  .line-clamp-6 {
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>