---
/*
  BookCard.astro

  Props:
    - title: string
    - author: string
    - price: string (optional)
    - img: string (optional) - path or URL to the cover image
    - href: string (optional) - if provided, the whole card becomes a link
    - sizeClasses: string (optional) - Tailwind width classes to control sizing

  Usage:
    <BookCard
      title="1984"
      author="George Orwell"
      price="£4.99"
      img="/cover080-cropped.jpg"
      href="/books/1984"
      sizeClasses="w-36 sm:w-44 md:w-52 lg:w-60"
    />
*/
const {
  title = "Book Title",
  author = "Author Name",
  price = "",
  img = "/cover080-cropped.jpg",
  href = null,
  sizeClasses = "w-full",
} = Astro.props;
---
<article
  class={`card bg-base-100 ${sizeClasses} shadow-2xl hover:shadow-2xl transition-all duration-75 transform hover:-translate-y-3 relative rounded-lg border-2 border-base-300`}
  style="box-shadow: 0 15px 35px -5px rgba(0, 0, 0, 0.2), 0 10px 15px -8px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(0, 0, 0, 0.05);"
  aria-label={`Book: ${title} by ${author}`}
>
  {href ? (
    <a
      href={href}
      class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-lg"
      aria-label={`View details for ${title} by ${author}`}
    >
      <figure style="aspect-ratio: 6 / 9;" class="w-full overflow-hidden rounded-t-md">
        <img
          src={img}
          alt={`Cover of ${title} by ${author}`}
          class="w-full h-full object-contain"
          loading="lazy"
        />
      </figure>

      <div class="card-body pb-12">
        <h3 class="text-sm opacity-70" style="color: var(--color-base-content);">{author}</h3>
        <h2 class="card-title text-base leading-tight text-base-content">{title}</h2>
      </div>

      {price && (
        <span class="absolute bottom-3 right-3 text-sm font-medium text-primary" aria-hidden="true">
          {price}
        </span>
      )}
    </a>
  ) : (
    <div class="block rounded-lg">
      <figure style="aspect-ratio: 6 / 9;" class="w-full overflow-hidden rounded-t-md">
        <img
          src={img}
          alt={`Cover of ${title} by ${author}`}
          class="w-full h-full object-contain"
          loading="lazy"
        />
      </figure>

      <div class="card-body pb-12">
        <h3 class="text-sm opacity-70" style="color: var(--color-base-content);">{author}</h3>
        <h2 class="card-title text-base leading-tight text-base-content">{title}</h2>
      </div>

      {price && (
        <span class="absolute bottom-3 right-3 text-sm font-medium text-primary" aria-hidden="true">
          {price}
        </span>
      )}
    </div>
  )}
</article>