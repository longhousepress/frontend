---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="max-w-2xl mx-auto py-12 text-center">
    <h1 class="text-3xl font-bold mb-4">Page Not Found</h1>
    <p class="text-lg opacity-70 mb-8">
      The page you requested was not available on the server.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="/" data-astro-prefetch class="btn btn-primary">
        Return Home
      </a>
      <a href="/catalog" data-astro-prefetch class="btn btn-outline">
        Browse Books
      </a>
    </div>
  </div>
</BaseLayout>
