---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { API_URL, SUPPORT_EMAIL } from '../../lib/constants';
---

<BaseLayout title="Submissions">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-4">Submissions</h1>
    <section class="prose max-w-none mb-8">
      <p class="mb-4">
        We publish poetry collections and short fiction anthologies as DRM-free ebooks. Submissions are always open.
      </p>

      <h2 class="text-xl font-semibold mb-3">What we're looking for</h2>

      <h3 class="text-lg font-medium mb-2">Poetry</h3>
      <p class="mb-4">
        Manuscripts of 40 or more poems. Traditional forms are preferred, but excellent free verse is also welcome.
      </p>

      <h3 class="text-lg font-medium mb-2">Short Fiction</h3>
      <p class="mb-4">
        Collections of 5 or more stories and at least 20,000 words total. Any genre is welcome, but sci-fi short fiction is a particular focus for us.
      </p>

      <h2 class="text-xl font-semibold mb-3">Who should submit</h2>
      <p class="mb-4">
        We always prefer to hear from writers directly, but agent submissions are also accepted.
      </p>

      <h2 class="text-xl font-semibold mb-3">Previously published work</h2>
      <p class="mb-4">
          Totally fine, as long as you have retained the rights to your work.
      </p>

      <h2 class="text-xl font-semibold mb-3">Simultaneous submissions</h2>
      <p class="mb-4">
        Totally fine, just let us know if your manuscript is taken elsewhere.
      </p>

      <h2 class="text-xl font-semibold mb-3">Response time</h2>
      <p class="mb-4">
        Two weeks.
      </p>

      <h2 class="text-xl font-semibold mb-3">On AI</h2>
      <p class="mb-6">
        We judge submissions on literary merit alone, not on the identity of the author. Most AI submissions fall very short of the literary standards required, and will be rejected on that basis; but if you have found a way to incorporate AI into your writing process to produce worthwhile art, we are interested.
      </p>

      <p class="text-sm opacity-60 mb-8">
        Questions before submitting? Email us at <a href={`mailto:${SUPPORT_EMAIL}`} class="link">{SUPPORT_EMAIL}</a>.
      </p>
    </section>

    <form
      action={`${API_URL}/api/submit`}
      method="POST"
      enctype="multipart/form-data"
      class="space-y-6"
    >
      <!-- Submitter Name -->
      <div>
        <label for="submitter" class="block text-sm font-medium mb-2">
          Submitter (real or pen name) <span class="text-error">*</span>
        </label>
        <input
          type="text"
          id="submitter"
          name="submitter"
          required
          class="input input-bordered w-full"
          placeholder="Your name"
        />
      </div>

      <!-- Submission Type -->
      <div>
        <label for="submission-type" class="block text-sm font-medium mb-2">
          Submission type <span class="text-error">*</span>
        </label>
        <select
          id="submission-type"
          name="submission_type"
          required
          class="select select-bordered w-full"
        >
          <option value="" disabled selected>Select a type</option>
          <option value="Poetry">Poetry</option>
          <option value="Short Fiction">Short Fiction</option>
          <option value="Other" disabled>Other</option>
        </select>
      </div>

      <!-- Optional Message -->
      <div>
        <label for="message" class="block text-sm font-medium mb-2">
          Optional message
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          class="textarea textarea-bordered w-full"
          placeholder="Any additional information you'd like to share…"
        ></textarea>
      </div>

      <!-- File Upload -->
      <div>
        <label for="file" class="block text-sm font-medium mb-2">
          File upload <span class="text-error">*</span>
        </label>
        <input
          type="file"
          id="file"
          name="file"
          required
          accept=".pdf,.doc,.docx,.txt,.md"
          class="file-input file-input-bordered file-input-primary w-full"
        />
        <p class="text-xs opacity-60 mt-2">
          Accepted formats: PDF, DOC, DOCX, TXT, MD
        </p>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button type="submit" class="btn btn-primary w-full">
          Submit
        </button>
      </div>
    </form>
  </div>
</BaseLayout>
