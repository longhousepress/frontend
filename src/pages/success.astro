---
import Layout from '../layouts/BaseLayout.astro';
// server-side: we don’t have the query param yet, so don’t pre-flight
---

<Layout title="Thank you">
  <main id="msg">Verifying…</main>
</Layout>

<script>
  const params = new URLSearchParams(location?.search ?? '');
  const orderId = params.get('order_id');
  const sessionId = params.get('session_id');
  const origin = import.meta.env.PUBLIC_ORIGIN || 'http://localhost:8000';

  const msgEl = document.getElementById('msg');
  if (!msgEl) {
    // If the message element is missing, nothing to update
  } else if (!orderId || !sessionId) {
    msgEl.textContent = 'Link expired or invalid.';
  } else {
    // Verify payment and get download URLs in one call
    fetch(`${origin}/api/order/${orderId}/verify?session_id=${encodeURIComponent(sessionId)}`, { method: 'POST' })
      .then(async r => {
        if (!r.ok) {
          msgEl.textContent = 'Payment not verified or link invalid.';
          return;
        }

        const data = await r.json();

        // Expecting an array of { token, url, title, expires_at }
        if (!Array.isArray(data) || data.length === 0) {
          msgEl.textContent = 'No downloads available.';
          return;
        }

        // Dump simple output: one <p> per edition with a link
        msgEl.innerHTML = `<p>Payment successful!</p>`;
        for (const item of data) {
          const p = document.createElement('p');
          const a = document.createElement('a');
          // item.url may be a relative path like /api/download/..., ensure origin if needed
          const href = item.url && item.url.startsWith('/') ? origin + item.url : (item.url || '#');
          a.href = href;
          a.textContent = item.title || href;
          a.setAttribute('download', '');
          p.appendChild(a);
          msgEl.appendChild(p);
        }
      })
      .catch(e => {
        console.error('verify error', e);
        msgEl.textContent = 'Error verifying payment.';
      });
  }
</script>
