---
import BaseLayout from '../layouts/BaseLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000';

const formatPrice = (price: number) => `£${(price / 100).toFixed(2)}`;
---

<BaseLayout title="Shopping Cart">
  <div class="max-w-2xl mx-auto py-6" data-api-url={API_URL}>
    <div class="flex h-full flex-col bg-base-100">
      <!-- Header -->
      <div class="flex-1 px-4 py-6 sm:px-6">
        <h1 class="text-2xl font-bold text-base-content mb-8">Shopping cart</h1>

        <!-- Loading state -->
        <div id="cart-loading" class="text-center py-12">
          <span class="loading loading-spinner loading-lg"></span>
          <p class="mt-4 opacity-70">Loading your cart...</p>
        </div>

        <!-- Cart items -->
        <ul id="cart-items" class="hidden divide-y divide-base-300"></ul>

        <!-- Empty state -->
        <div id="empty-cart" class="hidden text-center py-12">
          <p class="text-lg opacity-70">Your cart is empty.</p>
          <a href="/catalog" class="btn btn-primary mt-4">Browse Books</a>
        </div>
      </div>

      <!-- Footer -->
      <div id="cart-footer" class="hidden border-t border-base-300 px-4 py-6 sm:px-6">
        <div class="flex justify-between text-base font-medium mb-2">
          <p>Subtotal</p>
          <p id="subtotal">£0.00</p>
        </div>
        <p class="text-sm opacity-70">Shipping and taxes calculated at checkout.</p>

        <button id="checkout-btn" class="btn btn-primary btn-block mt-6">
          Checkout
        </button>

        <p class="mt-6 text-center text-sm opacity-70">
          or
          <a href="/catalog" class="font-medium text-primary hover:text-primary-focus ml-1">
            Continue Shopping →
          </a>
        </p>
      </div>
    </div>
  </div>

  <script>
    import { Cart } from '../lib/cart';

    const formatPrice = (price: number) => `£${(price / 100).toFixed(2)}`;

    const elements = {
      loading: document.getElementById('cart-loading')!,
      items: document.getElementById('cart-items')!,
      empty: document.getElementById('empty-cart')!,
      footer: document.getElementById('cart-footer')!,
      subtotal: document.getElementById('subtotal')!,
      checkout: document.getElementById('checkout-btn') as HTMLButtonElement,
    };

    function renderCart() {
      const items = Cart.getItems();

      elements.loading.classList.add('hidden');

      if (items.length === 0) {
        elements.empty.classList.remove('hidden');
        elements.items.classList.add('hidden');
        elements.footer.classList.add('hidden');
        return;
      }

      elements.empty.classList.add('hidden');
      elements.items.classList.remove('hidden');
      elements.footer.classList.remove('hidden');

      elements.items.innerHTML = items.map(item => `
        <li class="flex py-6 gap-4">
          <div class="shrink-0 overflow-hidden rounded-md border border-base-300" style="width: 96px; height: 144px;">
            ${item.cover ? `
              <img src="${item.cover}" alt="${item.title}" class="object-cover w-full h-full" />
            ` : `
              <div class="bg-base-200 w-full h-full flex items-center justify-center text-xs opacity-50">
                No Cover
              </div>
            `}
          </div>

          <div class="flex flex-1 flex-col justify-between">
            <div>
              <div class="flex justify-between text-base font-medium">
                <h3>
                  <a href="/books/${item.slug}" class="hover:text-primary transition-colors">
                    ${item.title}
                  </a>
                </h3>
                <p class="ml-4">${item.quantity > 1 ? `${item.quantity}× ` : ''}${formatPrice(item.price)}</p>
              </div>
              <p class="mt-1 text-sm opacity-70">${item.format || 'eBook'}</p>
              <p class="text-sm opacity-70">${item.language || 'English'}</p>
            </div>

            <div class="flex items-center justify-between text-sm">
              <div class="flex items-center gap-1">
                <button class="btn btn-xs h-6 min-h-0" data-action="dec" data-id="${item.id}">-</button>
                <input
                  type="text"
                  inputmode="numeric"
                  value="${item.quantity}"
                  class="input input-xs w-12 h-6 min-h-0 text-center"
                  data-id="${item.id}"
                />
                <button class="btn btn-xs h-6 min-h-0" data-action="inc" data-id="${item.id}">+</button>
              </div>
              <button class="font-medium text-primary hover:text-primary-focus" data-action="remove" data-id="${item.id}">
                Remove
              </button>
            </div>
          </div>
        </li>
      `).join('');

      elements.subtotal.textContent = formatPrice(Cart.getTotal());
    }

    // Event delegation for buttons - ONLY SET UP ONCE
    elements.items.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('button') as HTMLButtonElement;
      if (!btn) return;

      const { action, id } = btn.dataset;
      // dataset values are strings; convert to numeric id for Cart which uses numeric ids
      const idNum = id !== undefined ? Number(id) : NaN;
      if (Number.isNaN(idNum)) return;

      const item = Cart.getItems().find(i => i.id === idNum);
      if (!item) return;

      if (action === 'inc') Cart.updateQuantity(idNum, item.quantity + 1);
      if (action === 'dec' && item.quantity > 1) Cart.updateQuantity(idNum, item.quantity - 1);
      if (action === 'remove') Cart.removeItem(idNum);

      renderCart();
    });

    // Event delegation for quantity input focus - select all on click
    elements.items.addEventListener('focus', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'INPUT') return;

      const input = target as HTMLInputElement;
      input.select();
    }, true);

    // Event delegation for quantity inputs blur
    elements.items.addEventListener('blur', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'INPUT') return;

      const input = target as HTMLInputElement;
      const value = parseInt(input.value) || 1;
      const idNum = input.dataset.id !== undefined ? Number(input.dataset.id) : NaN;
      if (Number.isNaN(idNum)) return;
      Cart.updateQuantity(idNum, value);
      renderCart();
    }, true);

    // Checkout handler
    elements.checkout.addEventListener('click', async () => {
      const items = Cart.getItems().map(item => ({
        edition_id: Number(item.id),
        quantity: item.quantity
      }));

      if (items.length === 0) return;

      try {
        elements.checkout.disabled = true;
        const apiUrl = document.querySelector<HTMLElement>('[data-api-url]')?.dataset.apiUrl || '';

        const res = await fetch(`${apiUrl}/api/checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items })
        });

        const data = await res.json();

        if (!res.ok) {
          alert(data?.message || `Checkout failed (${res.status})`);
          return;
        }

        if (data?.url) {
          window.location.href = data.url;
        } else {
          alert('Checkout session not returned.');
        }
      } catch (err) {
        console.error('Checkout error:', err);
        alert('Network error. Please try again.');
      } finally {
        elements.checkout.disabled = false;
      }
    });

    // Initial render
    renderCart();

    // Listen for cart updates
    window.addEventListener('cart-updated', renderCart);
  </script>
</BaseLayout>
