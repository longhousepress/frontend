---
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch 2 random books from the API
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000';
const response = await fetch(`${API_URL}/api/books?lang=eng`);
const allBooks = await response.json();

// Get 2 random books
const shuffled = [...allBooks].sort(() => 0.5 - Math.random());
const cartBooks = shuffled.slice(0, 2);

// Fetch full details for each book
const booksWithDetails = await Promise.all(
  cartBooks.map(async (book: any) => {
    const detailResponse = await fetch(`${API_URL}/api/books/${book.book_slug}`);
    const bookData = await detailResponse.json();
    return {
      ...book,
      details: bookData,
      edition: bookData.editions[0]
    };
  })
);

// Format price helper (500 -> £5.00)
const formatPrice = (price: number) => {
  return `£${(price / 100).toFixed(2)}`;
};

// Calculate subtotal
const subtotal = booksWithDetails.reduce((sum, book) => sum + book.price, 0);
---

<BaseLayout title="Shopping Cart">
  <div class="max-w-2xl mx-auto py-6" data-api-url={API_URL}>
    <div class="flex h-full flex-col bg-base-100">
      <div class="flex-1 px-4 py-6 sm:px-6">
        <div class="flex items-start justify-between mb-8">
          <h1 class="text-2xl font-bold text-base-content">Shopping cart</h1>
        </div>

        <div class="flow-root">
          <ul role="list" class="divide-y divide-base-300">
            {booksWithDetails.map((book) => (
              <li class="flex py-6 gap-4">
                <div class="shrink-0 overflow-hidden rounded-md border border-base-300" style="width: 96px; height: 144px;">
                  <img 
                    src={book.edition.cover} 
                    alt={`Cover of ${book.title} by ${book.author}`}
                    class="object-cover"
                    style="width: 96px; height: 144px;"
                  />
                </div>

                <div class="flex flex-1 flex-col justify-between">
                  <div>
                    <div class="flex justify-between text-base font-medium text-base-content">
                      <h3>
                        <a href={`/books/${book.book_slug}`} class="hover:text-primary transition-colors">
                          {book.title}
                        </a>
                      </h3>
                      <p class="ml-4 item-price">{formatPrice(book.price)}</p>
                    </div>
                    <p class="mt-1 text-sm opacity-70">{book.author}</p>
                    <p class="mt-1 text-sm opacity-70">{book.edition.format || 'eBook'}</p>
                    <p class="mt-1 text-sm opacity-70">{book.edition.language || 'English'}</p>
                  </div>
                  <div class="flex items-center justify-between text-sm">
                    <div class="flex items-center gap-1">
                        <button class="btn btn-xs min-h-0 h-6 qty-decrease">-</button>
                        <input type="text" inputmode="numeric" pattern="[0-9]*" value="1" class="input input-xs w-12 h-6 min-h-0 text-center py-0 qty-input" data-price={book.price} data-edition-id={book.edition.id} />
                        <button class="btn btn-xs min-h-0 h-6 qty-increase">+</button>
                      </div>

                    <div class="flex">
                      <button type="button" class="font-medium text-primary hover:text-primary-focus transition-colors remove-item">
                        Remove
                      </button>
                    </div>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Empty cart message (hidden by default) -->
        <div id="empty-cart" class="hidden text-center py-12">
          <p class="text-lg opacity-70">Your cart is empty.</p>
          <a href="/catalog" class="btn btn-primary mt-4">Browse Books</a>
        </div>
      </div>

      <div class="border-t border-base-300 px-4 py-6 sm:px-6" id="cart-footer">
        <div class="flex justify-between text-base font-medium text-base-content mb-2">
          <p>Subtotal</p>
          <p id="subtotal-amount">{formatPrice(subtotal)}</p>
        </div>
        <p class="mt-0.5 text-sm opacity-70">Shipping and taxes calculated at checkout.</p>
        
        <div class="mt-6">
          <button class="btn btn-primary btn-block" id="checkout-btn">
            Checkout
          </button>
        </div>
        
        <div class="mt-6 flex justify-center text-center text-sm opacity-70">
          <p>
            or
            <a href="/catalog" class="font-medium text-primary hover:text-primary-focus ml-1">
              Continue Shopping
              <span aria-hidden="true"> →</span>
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Format price helper (500 -> £5.00)
    function formatPrice(price: number): string {
      return `£${(price / 100).toFixed(2)}`;
    }

    // Calculate and update subtotal
    function updateSubtotal() {
      const cartItems = document.querySelectorAll('ul[role="list"] > li');
      let total = 0;

      cartItems.forEach((item) => {
        if (!item.classList.contains('hidden')) {
          const qtyInput = item.querySelector('.qty-input') as HTMLInputElement;
          const price = parseInt(qtyInput.dataset.price || '0');
          const quantity = parseInt(qtyInput.value);
          total += price * quantity;
          
          // Update item price display with quantity multiplier
          const priceEl = item.querySelector('.item-price');
          if (priceEl) {
            if (quantity > 1) {
              priceEl.textContent = `${quantity}× ${formatPrice(price)}`;
            } else {
              priceEl.textContent = formatPrice(price);
            }
          }
        }
      });

      const subtotalEl = document.getElementById('subtotal-amount');
      if (subtotalEl) {
        subtotalEl.textContent = formatPrice(total);
      }

      // Check if cart is empty
      const visibleItems = Array.from(cartItems).filter(item => !item.classList.contains('hidden'));
      const emptyCart = document.getElementById('empty-cart');
      const cartFooter = document.getElementById('cart-footer');
      
      if (visibleItems.length === 0) {
        emptyCart?.classList.remove('hidden');
        cartFooter?.classList.add('hidden');
      }
    }

    // Handle quantity increase
    document.querySelectorAll('.qty-increase').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = btn.previousElementSibling as HTMLInputElement;
        const currentQty = parseInt(input.value) || 1;
        input.value = String(currentQty + 1);
        updateSubtotal();
      });
    });

    // Handle quantity decrease
    document.querySelectorAll('.qty-decrease').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = btn.nextElementSibling as HTMLInputElement;
        const currentQty = parseInt(input.value) || 1;
        if (currentQty > 1) {
          input.value = String(currentQty - 1);
          updateSubtotal();
        }
      });
    });

    // Auto-select value on focus for better UX
    document.querySelectorAll('.qty-input').forEach((input) => {
      input.addEventListener('focus', () => {
        const inputEl = input as HTMLInputElement;
        inputEl.select();
      });
      
      input.addEventListener('input', () => {
        const inputEl = input as HTMLInputElement;
        let value = inputEl.value;
        
        // Remove any non-digit characters
        value = value.replace(/[^0-9]/g, '');
        
        // Allow empty during input (will be fixed on blur)
        inputEl.value = value;
        
        // Update subtotal with current value or treat empty as 1
        const numValue = parseInt(value) || 1;
        
        // Temporarily update for calculation
        const originalValue = inputEl.value;
        inputEl.value = String(numValue);
        updateSubtotal();
        inputEl.value = originalValue;
      });
      
      // Also validate on blur to catch edge cases
      input.addEventListener('blur', () => {
        const inputEl = input as HTMLInputElement;
        const value = parseInt(inputEl.value);
        
        if (isNaN(value) || value < 1 || inputEl.value === '') {
          inputEl.value = '1';
          updateSubtotal();
        }
      });
    });

    // Handle remove item
    document.querySelectorAll('.remove-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const listItem = btn.closest('li');
        if (listItem) {
          listItem.classList.add('hidden');
          updateSubtotal();
        }
      });
    });

    // Handle checkout button
    const checkoutBtn = document.getElementById('checkout-btn');
    checkoutBtn?.addEventListener('click', async () => {
      // Collect visible items with edition id and quantity
      const cartItems = Array.from(document.querySelectorAll('ul[role="list"] > li'))
        .filter(li => !li.classList.contains('hidden'));

      const items = cartItems.map(li => {
        const qtyInput = li.querySelector('.qty-input') as HTMLInputElement | null;
        const editionId = qtyInput?.dataset?.editionId ?? null;
        const quantity = qtyInput ? parseInt(qtyInput.value || '1', 10) : 1;
        return {
          edition_id: editionId,
          quantity: quantity
        };
      }).filter(item => item.edition_id);

      if (items.length === 0) {
        alert('Your cart is empty.');
        return;
      }

      const payload = { items };

      try {
        // Disable button to prevent duplicate submits
        checkoutBtn.setAttribute('disabled', 'true');

        const apiUrl = (document.querySelector('[data-api-url]') as HTMLElement | null)?.dataset?.apiUrl || '';
        const resp = await fetch(`${apiUrl}/api/checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await resp.json().catch(() => ({}));

        if (!resp.ok) {
          alert(data?.message || `Checkout failed (${resp.status})`);
          console.error('Checkout error response:', data);
          return;
        }

        // Expect backend to return CheckoutSession { url: String }
        if (data && data.url) {
          window.location.href = data.url;
        } else {
          alert('Checkout session not returned by server.');
          console.error('Unexpected checkout response:', data);
        }
      } catch (err) {
        console.error('Network error during checkout', err);
        alert('Network error during checkout. Please try again.');
      } finally {
        checkoutBtn.removeAttribute('disabled');
      }
    });
  </script>
</BaseLayout>