---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CatalogGrid from '../../../components/CatalogGrid.astro';
import { BUILD_API_URL } from '../../../lib/constants';
import { getPriceForCurrency, sortEditions } from '../../../lib/utils';
import { locales, useTranslations, getLanguage, getCurrencyConfig } from '../../../lib/i18n';
import type { Book, Contributor } from '../../../types/book';

const coverImages = import.meta.glob<{ default: ImageMetadata }>('../../../assets/*/cover/*');

async function getCoverImage(coverFilename: string, bookSlug: string) {
  if (!coverFilename) return coverFilename;
  const exactPath = `../../../assets/${bookSlug}/cover/${coverFilename}`;
  const imageModule = coverImages[exactPath];
  if (imageModule) {
    const image = await imageModule();
    return image.default;
  }
  return coverFilename;
}

export async function getStaticPaths() {
  const AUTHOR_ROLE_ID = 1;

  return (await Promise.all(locales.map(async lang => {
    const language = getLanguage(lang);
    const response = await fetch(`${BUILD_API_URL}/api/books?language=${language}`);
    const booksRaw: Book[] = await response.json();

    const authorsMap = new Map<string, Contributor>();
    (booksRaw || []).forEach((book: Book) => {
      (book.contributors || []).forEach((contributor: Contributor) => {
        if (contributor.role_id === AUTHOR_ROLE_ID && contributor.slug) {
          authorsMap.set(contributor.slug, contributor);
        }
      });
    });

    return Array.from(authorsMap.values()).map(author => ({
      params: { lang, slug: author.slug },
      props: { author },
    }));
  }))).flat();
}

const AUTHOR_ROLE_ID = 1;

const { lang, slug } = Astro.params;
const { author } = Astro.props;
const t = useTranslations(lang);
const currency = getCurrencyConfig(lang);

const response = await fetch(`${BUILD_API_URL}/api/books?language=${getLanguage(lang)}`);
const booksRaw: Book[] = await response.json();

const localizedAuthor = (booksRaw || [])
  .flatMap(book => book.contributors)
  .find(c => c.slug === slug && c.role_id === AUTHOR_ROLE_ID);
const authorBio = localizedAuthor?.bio ?? author.bio;

const booksWithPaths = (booksRaw || [])
  .flatMap((book: Book) => {
    const hasAuthor = book.contributors.some(
      c => c.slug === slug && c.role_id === AUTHOR_ROLE_ID
    );
    if (!hasAuthor) return [];

    return (book.editions || [])
      .map((edition: any) => {
        const price = edition.prices ? getPriceForCurrency(edition.prices, currency.code) : null;
        if (price === null) return null;
        return {
          id: edition.id,
          title: edition.title,
          author: edition.author_name,
          price,
          coverPath: edition.cover,
          description: edition.short_description,
          book_slug: book.book_slug,
          categories: edition.categories || [],
          format: edition.format || 'eBook',
          language: edition.language || null,
          page_count: edition.page_count || null,
          translator: edition.translator_name || null,
          publication_date: edition.publication_date || null,
          isbn: edition.isbn || null,
          original: edition.original || false,
        };
      })
      .filter((edition: any) => edition !== null);
  });

const booksWithCovers = await Promise.all(
  booksWithPaths.map(async (book: any) => ({
    ...book,
    cover: await getCoverImage(book.coverPath, book.book_slug),
  }))
);

const storefrontLanguage = getLanguage(lang);
const localBooks = sortEditions(booksWithCovers.filter((b: any) => b.language === storefrontLanguage));
const foreignBooks = sortEditions(booksWithCovers.filter((b: any) => b.language !== storefrontLanguage));

const allCategories = Array.from(
  new Set([...localBooks, ...foreignBooks].flatMap((b: any) => b.categories || []))
).sort() as string[];
---

<BaseLayout title={author.name}>
  <CatalogGrid {lang} {localBooks} {foreignBooks} {allCategories}>
    <div slot="header" class="max-w-7xl mx-auto mb-6 text-center">
      <h2 class="text-2xl font-semibold">{author.name}</h2>
      {authorBio && (
        <p class="text-sm opacity-70 mt-2 max-w-2xl mx-auto">{authorBio}</p>
      )}
      <p class="text-sm opacity-70 mt-1">
        {localBooks.length + foreignBooks.length} {localBooks.length + foreignBooks.length === 1 ? t('author_book_singular') : t('author_book_plural')}
      </p>
    </div>
  </CatalogGrid>
</BaseLayout>
