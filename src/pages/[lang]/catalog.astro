---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import { BUILD_API_URL } from '../../lib/constants';
import { getPriceForCurrency, formatPrice } from '../../lib/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { locales, useTranslations, getLanguage, getCurrencyConfig } from '../../lib/i18n';
import type { Book } from '../../types/book';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const currency = getCurrencyConfig(lang);

const coverImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*/cover/*');

async function getCoverImage(coverFilename: string, bookSlug: string) {
  if (!coverFilename) return coverFilename;
  const exactPath = `../../assets/${bookSlug}/cover/${coverFilename}`;
  const imageModule = coverImages[exactPath];
  if (imageModule) {
    const image = await imageModule();
    return image.default;
  }
  return coverFilename;
}

const response = await fetch(`${BUILD_API_URL}/api/books?language=${getLanguage(lang)}`);
const booksRaw: Book[] = await response.json();

const booksWithPaths = (booksRaw || [])
  .flatMap((book: Book) => {
    return (book.editions || [])
      .map((edition: any) => {
        const price = edition.prices ? getPriceForCurrency(edition.prices, currency.code) : null;
        if (price === null) return null;
        return {
          id: edition.id,
          title: edition.title,
          author: edition.author_name,
          price,
          coverPath: edition.cover,
          description: edition.short_description,
          book_slug: book.book_slug,
          categories: edition.categories || [],
          format: edition.format || 'eBook',
          language: edition.language || null,
          page_count: edition.page_count || null,
          translator: edition.translator_name || null,
          publication_date: edition.publication_date || null,
          isbn: edition.isbn || null,
          original: edition.original || false,
        };
      })
      .filter((edition: any) => edition !== null);
  });

const booksWithCovers = await Promise.all(
  booksWithPaths.map(async (book: any) => ({
    ...book,
    cover: await getCoverImage(book.coverPath, book.book_slug),
  }))
);

function sortEditions(editions: any[]) {
  return editions.sort((a, b) => {
    if (a.original !== b.original) return a.original ? -1 : 1;
    if (a.publication_date && b.publication_date) return b.publication_date.localeCompare(a.publication_date);
    if (a.publication_date) return -1;
    if (b.publication_date) return 1;
    return 0;
  });
}

const storefrontLanguage = getLanguage(lang);
const localBooks = sortEditions(booksWithCovers.filter((b: any) => b.language === storefrontLanguage));
const foreignBooks = sortEditions(booksWithCovers.filter((b: any) => b.language !== storefrontLanguage));
const books = [...localBooks, ...foreignBooks];

const allCategories = Array.from(
  new Set(books.flatMap((book: any) => book.categories || []))
).sort() as string[];
---

<BaseLayout title={t('catalog_title')}>
  <div class="py-6">
    <div class="max-w-7xl mx-auto mb-6 text-center">
      <h2 class="text-2xl font-semibold">{t('catalog_title')}</h2>
    </div>

    <div class="max-w-7xl mx-auto mb-6">
      <div class="flex justify-between items-start sm:items-center flex-col sm:flex-row gap-4 sm:gap-0">
        <div class="relative w-full sm:w-auto">
          <div class="flex items-center sm:block">
            <button
              id="filter-toggle"
              class="btn btn-sm btn-square h-8 min-h-8 shrink-0 relative z-10"
              aria-label="Toggle filters"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
              </svg>
            </button>
          </div>

          <div id="filter-panel" class="filter-panel overflow-hidden transition-all duration-300 ease-in-out">
            <div class="filter-panel-content bg-base-300 p-3 flex flex-col sm:flex-row sm:items-center gap-3">
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
                <span class="text-xs font-medium whitespace-nowrap">{t('catalog_filter_genre')}</span>
                <span class="hidden sm:inline text-xs opacity-30">|</span>
                <div class="flex items-center gap-3 flex-wrap sm:flex-nowrap">
                  {allCategories.map((category: string) => (
                    <label class="flex items-center gap-1 cursor-pointer whitespace-nowrap">
                      <input
                        type="checkbox"
                        class="checkbox checkbox-xs checkbox-primary genre-filter rounded-sm"
                        value={category}
                      />
                      <span class="text-xs">{category}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
                <span class="text-xs font-medium whitespace-nowrap">{t('catalog_filter_type')}</span>
                <span class="hidden sm:inline text-xs opacity-30">|</span>
                <div class="flex items-center gap-3 flex-wrap sm:flex-nowrap">
                  <label class="flex items-center gap-1 cursor-pointer whitespace-nowrap">
                    <input
                      type="checkbox"
                      class="checkbox checkbox-xs checkbox-primary original-filter rounded-sm"
                      value="original"
                    />
                    <span class="text-xs">{t('catalog_filter_original')}</span>
                  </label>
                  <label class="flex items-center gap-1 cursor-pointer whitespace-nowrap">
                    <input
                      type="checkbox"
                      class="checkbox checkbox-xs checkbox-primary original-filter rounded-sm"
                      value="classic"
                    />
                    <span class="text-xs">{t('catalog_filter_classic')}</span>
                  </label>
                </div>
              </div>
            </div>
          </div>
        </div>

      <label class="floating-label relative w-full sm:w-[calc((100%-2rem)/2)] md:w-[calc((100%-4rem)/3)] lg:w-[calc((100%-6rem)/4)] xl:w-[calc((100%-8rem)/5)]">
        <input type="text" id="search-input" placeholder={t('catalog_search_placeholder')} class="input input-sm pr-10 w-full" />
        <span>{t('catalog_search_label')}</span>
        <kbd id="search-kbd" class="kbd kbd-sm absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none">/</kbd>
      </label>
      </div>
    </div>

    <div class="max-w-7xl mx-auto">
      <div id="books-grid" class="grid gap-8 justify-items-center grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        {localBooks.map((edition: any) => (
          <div
            class="book-item w-full max-w-60"
            data-title={edition.title.toLowerCase()}
            data-author={edition.author.toLowerCase()}
            data-categories={JSON.stringify(edition.categories || [])}
            data-price={(edition.price / 100).toFixed(2)}
            data-original={edition.original ? 'true' : 'false'}
            data-foreign="false"
          >
            <BookCard
              title={edition.title}
              author={edition.author}
              price={formatPrice(edition.price, currency)}
              img={edition.cover}
              href={getRelativeLocaleUrl(lang, `/books/${edition.book_slug}`)}
              description={edition.description}
              categories={edition.categories}
              original={edition.original}
              ribbonLabel={t('book_original_ribbon')}
              byText={t('book_by')}
              coverOfText={t('book_cover_of')}
              bookLabelText={t('book_card_label')}
              viewDetailsText={t('book_card_view_details')}
            />
          </div>
        ))}

        {foreignBooks.length > 0 && (
          <div id="foreign-divider" class="col-span-full w-full flex items-center gap-4 my-2">
            <hr class="flex-1 border-base-content/20" />
            <span class="text-sm opacity-50 whitespace-nowrap">{t('catalog_foreign_books_divider')}</span>
            <hr class="flex-1 border-base-content/20" />
          </div>
        )}

        {foreignBooks.map((edition: any) => (
          <div
            class="book-item w-full max-w-60"
            data-title={edition.title.toLowerCase()}
            data-author={edition.author.toLowerCase()}
            data-categories={JSON.stringify(edition.categories || [])}
            data-price={(edition.price / 100).toFixed(2)}
            data-original={edition.original ? 'true' : 'false'}
            data-foreign="true"
          >
            <BookCard
              title={edition.title}
              author={edition.author}
              price={formatPrice(edition.price, currency)}
              img={edition.cover}
              href={getRelativeLocaleUrl(lang, `/books/${edition.book_slug}`)}
              description={edition.description}
              categories={edition.categories}
              original={edition.original}
              ribbonLabel={t('book_original_ribbon')}
              byText={t('book_by')}
              coverOfText={t('book_cover_of')}
              bookLabelText={t('book_card_label')}
              viewDetailsText={t('book_card_view_details')}
            />
          </div>
        ))}
      </div>

      <div id="no-results" class="hidden text-center py-12">
        <p class="text-lg opacity-70">{t('catalog_no_results')}</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .filter-panel {
    width: 100%;
    max-height: 0;
    opacity: 0;
    margin-top: 0.5rem;
    border-radius: 0.5rem;
    transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
  }

  .filter-panel.open {
    max-height: 500px;
    opacity: 1;
  }

  .filter-panel-content {
    border-radius: 0.5rem;
  }

  @media (min-width: 640px) {
    .filter-panel {
      position: absolute;
      top: 0;
      left: 28px;
      width: 0;
      max-height: none;
      height: 2rem;
      margin-top: 0;
      border-radius: 0 0.5rem 0.5rem 0;
      display: flex;
      align-items: center;
      opacity: 0;
      transition: width 0.3s ease-in-out, opacity 0.3s ease-in-out;
    }

    .filter-panel.open {
      width: auto;
      max-height: none;
      opacity: 1;
    }

    .filter-panel-content {
      white-space: nowrap;
      height: 2rem;
      border-radius: 0 0.5rem 0.5rem 0;
      padding-left: 0.75rem;
      padding-right: 0.75rem;
      display: flex;
      flex-direction: row;
      align-items: center;
    }
  }
</style>

<script>
  function setupSearchShortcuts() {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchKbd = document.getElementById('search-kbd');
    if (!searchInput) return;
    searchInput.addEventListener('focus', () => { if (searchKbd) searchKbd.textContent = 'Esc'; });
    searchInput.addEventListener('blur', () => { if (searchKbd) searchKbd.textContent = '/'; });
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
        e.preventDefault();
        searchInput.focus();
      }
      if (e.key === 'Escape' && document.activeElement === searchInput) searchInput.blur();
    });
  }

  function setupFilterToggle() {
    const filterToggle = document.getElementById('filter-toggle');
    const filterPanel = document.getElementById('filter-panel') as HTMLElement;
    let isFilterOpen = false;
    if (!filterToggle || !filterPanel) return;
    filterToggle.addEventListener('click', () => {
      isFilterOpen = !isFilterOpen;
      filterPanel.classList.toggle('open', isFilterOpen);
    });
    document.addEventListener('click', (e) => {
      if (isFilterOpen && !filterPanel.contains(e.target as Node) && !filterToggle.contains(e.target as Node)) {
        isFilterOpen = false;
        filterPanel.classList.remove('open');
      }
    });
  }

  function setupFiltering() {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const booksGrid = document.getElementById('books-grid');
    const noResults = document.getElementById('no-results');
    const bookItems = document.querySelectorAll('.book-item');
    const genreFilters = document.querySelectorAll('.genre-filter') as NodeListOf<HTMLInputElement>;
    const originalFilters = document.querySelectorAll('.original-filter') as NodeListOf<HTMLInputElement>;
    if (!searchInput || !booksGrid) return;

    const foreignDivider = document.getElementById('foreign-divider');

    function filterBooks() {
      const query = searchInput.value.toLowerCase().trim();
      const selectedGenres = Array.from(genreFilters).filter(c => c.checked).map(c => c.value);
      const selectedTypes = Array.from(originalFilters).filter(c => c.checked).map(c => c.value);
      let visibleCount = 0;
      let visibleForeignCount = 0;
      bookItems.forEach(item => {
        const el = item as HTMLElement;
        const title = el.dataset.title || '';
        const author = el.dataset.author || '';
        const categories = JSON.parse(el.dataset.categories || '[]');
        const isOriginal = el.dataset.original === 'true';
        const isForeign = el.dataset.foreign === 'true';
        const matchesSearch = !query || title.includes(query) || author.includes(query);
        const matchesGenre = selectedGenres.length === 0 || selectedGenres.some(g => categories.includes(g));
        const matchesType = selectedTypes.length === 0 ||
          (selectedTypes.includes('original') && isOriginal) ||
          (selectedTypes.includes('classic') && !isOriginal);
        const matches = matchesSearch && matchesGenre && matchesType;
        el.style.display = matches ? '' : 'none';
        if (matches) {
          visibleCount++;
          if (isForeign) visibleForeignCount++;
        }
      });
      if (foreignDivider) foreignDivider.style.display = visibleForeignCount > 0 ? '' : 'none';
      booksGrid?.classList.toggle('hidden', visibleCount === 0);
      noResults?.classList.toggle('hidden', visibleCount > 0);
    }

    searchInput.addEventListener('input', filterBooks);
    genreFilters.forEach(c => c.addEventListener('change', filterBooks));
    originalFilters.forEach(c => c.addEventListener('change', filterBooks));
  }

  document.addEventListener('astro:page-load', () => {
    setupSearchShortcuts();
    setupFilterToggle();
    setupFiltering();
  });
</script>
