---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SELECTED_CURRENCY, API_URL } from '../../lib/constants';
import { formatPrice } from '../../lib/utils';
import { getImage } from 'astro:assets';
import { locales, defaultLocale, useTranslations, getLocalePath } from '../../lib/i18n';

export function getStaticPaths() {
  return locales
    .filter(l => l !== defaultLocale)
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const coverImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*/cover/*');

const coverUrlMap: Record<string, string> = {};
for (const [path, importFn] of Object.entries(coverImages)) {
  const pathParts = path.split('/');
  const bookSlug = pathParts[pathParts.length - 3];
  const filename = pathParts[pathParts.length - 1];
  if (bookSlug && filename) {
    const imageModule = await importFn();
    const optimizedImage = await getImage({ src: imageModule.default, format: 'webp', width: 200 });
    coverUrlMap[`${bookSlug}/${filename}`] = optimizedImage.src;
  }
}

const CURRENCY = SELECTED_CURRENCY.toLowerCase();
const localePrefix = getLocalePath(lang, '');
---

<BaseLayout title={t('checkout_title')}>
  <div class="max-w-2xl mx-auto py-6" data-api-url={API_URL} data-currency={CURRENCY} data-cover-map={JSON.stringify(coverUrlMap)} data-locale-prefix={localePrefix}>
    <div class="flex h-full flex-col bg-base-100">
      <div class="flex-1 px-4 py-6 sm:px-6">
        <h1 id="cart-header" class="text-2xl font-bold text-base-content mb-8">{t('checkout_header')}</h1>

        <div id="cart-loading" class="text-center py-12">
          <span class="loading loading-spinner loading-lg"></span>
          <p class="mt-4 opacity-70">{t('checkout_loading')}</p>
        </div>

        <ul id="cart-items" class="hidden divide-y divide-base-300"></ul>

        <template id="cart-item-template">
          <li class="flex py-6 gap-4">
            <div class="shrink-0 overflow-hidden rounded-md border border-base-300" style="width: 96px; height: 144px;">
              <img class="item-cover object-cover w-full h-full" alt="" />
              <div class="item-no-cover bg-base-200 w-full h-full flex items-center justify-center text-xs opacity-50">
                {t('checkout_no_cover')}
              </div>
            </div>

            <div class="flex flex-1 flex-col justify-between">
              <div>
                <div class="flex justify-between text-base font-medium">
                  <h3>
                    <a class="item-link hover:text-primary transition-colors" href="">
                      <span class="item-title"></span>
                    </a>
                  </h3>
                  <p class="ml-4 item-price"></p>
                </div>
                <p class="mt-1 text-sm opacity-70 item-format"></p>
                <p class="text-sm opacity-70 item-language"></p>
              </div>

              <div class="flex items-center justify-between text-sm">
                <div class="flex items-center gap-1">
                  <button class="btn btn-xs h-6 min-h-0" data-action="dec">-</button>
                  <input
                    type="text"
                    inputmode="numeric"
                    class="item-quantity input input-xs w-12 h-6 min-h-0 text-center"
                  />
                  <button class="btn btn-xs h-6 min-h-0" data-action="inc">+</button>
                </div>
                <button class="font-medium text-primary hover:text-primary-focus" data-action="remove">
                  {t('checkout_remove')}
                </button>
              </div>
            </div>
          </li>
        </template>

        <div id="empty-cart" class="hidden text-center py-12">
          <p class="text-lg opacity-70 mb-4">{t('checkout_empty')}</p>
          <a href={getLocalePath(lang, '/catalog')} data-astro-prefetch class="inline-block text-primary hover:text-primary-focus font-medium py-3 px-4">{t('checkout_browse')}</a>
        </div>
      </div>

      <form id="checkout-form" class="hidden border-t border-base-300 px-4 py-6 sm:px-6">
        <div class="flex justify-between text-base font-medium mb-2">
          <p>{t('checkout_subtotal')}</p>
          <p id="subtotal">£0.00</p>
        </div>
        <p class="text-sm opacity-70">{t('checkout_shipping')}</p>

        <div class="border-t border-base-300 mt-6 pt-6">
          <p class="text-base font-medium mb-2">{t('checkout_email_label')}</p>
          <p class="text-sm opacity-70 mb-4">{t('checkout_email_hint')}</p>
          <input class="input validator w-full" type="email" required placeholder={t('checkout_email_placeholder')} id="email-input" />
          <div class="validator-hint">{t('checkout_email_invalid')}</div>
        </div>

        <button type="submit" id="checkout-btn" class="btn btn-primary btn-block mt-6">
          {t('checkout_btn')}
        </button>

        <p class="mt-6 text-center text-sm opacity-70">
          {t('checkout_or')}
          <a href={getLocalePath(lang, '/catalog')} data-astro-prefetch class="font-medium text-primary hover:text-primary-focus ml-1">
            {t('checkout_continue')}
          </a>
        </p>
      </form>
    </div>
  </div>

  <script>
    import { Cart } from '../../lib/cart';
    import { formatPrice } from '../../lib/utils';

    function setupCheckoutPage() {
      const elements = {
        loading: document.getElementById('cart-loading')!,
        header: document.getElementById('cart-header')!,
        items: document.getElementById('cart-items')!,
        empty: document.getElementById('empty-cart')!,
        form: document.getElementById('checkout-form') as HTMLFormElement,
        subtotal: document.getElementById('subtotal')!,
        checkout: document.getElementById('checkout-btn') as HTMLButtonElement,
        emailInput: document.getElementById('email-input') as HTMLInputElement,
        template: document.getElementById('cart-item-template') as HTMLTemplateElement,
      };

      function createCartItemElement(item: ReturnType<typeof Cart.getItems>[0]) {
        const clone = elements.template.content.cloneNode(true) as DocumentFragment;
        const li = clone.querySelector('li')!;

        li.querySelectorAll('[data-action]').forEach(el => {
          (el as HTMLElement).dataset.id = String(item.id);
        });
        (li.querySelector('.item-quantity') as HTMLInputElement).dataset.id = String(item.id);

        const cover = li.querySelector('.item-cover') as HTMLImageElement;
        const noCover = li.querySelector('.item-no-cover') as HTMLDivElement;

        const rootEl = document.querySelector<HTMLElement>('[data-cover-map]')!;
        const coverMap = JSON.parse(rootEl?.dataset.coverMap || '{}');
        const coverFilename = item.cover ? item.cover.split('/').pop() : null;
        const coverKey = (item.slug && coverFilename) ? `${item.slug}/${coverFilename}` : null;
        const optimizedCoverUrl = coverKey ? coverMap[coverKey] : null;

        if (optimizedCoverUrl) {
          cover.src = optimizedCoverUrl;
          cover.alt = item.title;
          noCover.classList.add('hidden');
        } else if (item.cover && item.slug) {
          const apiUrl = rootEl?.dataset.apiUrl || '';
          cover.src = `${apiUrl}/covers/${item.slug}/${item.cover}`;
          cover.alt = item.title;
          noCover.classList.add('hidden');
        } else {
          cover.classList.add('hidden');
          noCover.classList.remove('hidden');
        }

        const localePrefix = rootEl?.dataset.localePrefix || '';
        const link = li.querySelector('.item-link') as HTMLAnchorElement;
        link.href = `${localePrefix}/books/${item.slug}`;
        (li.querySelector('.item-title') as HTMLElement).textContent = item.title;

        const priceText = item.quantity > 1 ? `${item.quantity}× ${formatPrice(item.price)}` : formatPrice(item.price);
        (li.querySelector('.item-price') as HTMLElement).textContent = priceText;

        (li.querySelector('.item-format') as HTMLElement).textContent = item.format || 'eBook';
        (li.querySelector('.item-language') as HTMLElement).textContent = item.language || '';
        (li.querySelector('.item-quantity') as HTMLInputElement).value = String(item.quantity);

        return li;
      }

      function renderCart() {
        const items = Cart.getItems();
        elements.loading.classList.add('hidden');

        if (items.length === 0) {
          elements.header.classList.add('hidden');
          elements.empty.classList.remove('hidden');
          elements.items.classList.add('hidden');
          elements.form.classList.add('hidden');
          return;
        }

        elements.header.classList.remove('hidden');
        elements.empty.classList.add('hidden');
        elements.items.classList.remove('hidden');
        elements.form.classList.remove('hidden');

        elements.items.innerHTML = '';
        items.forEach(item => {
          elements.items.appendChild(createCartItemElement(item));
        });

        elements.subtotal.textContent = formatPrice(Cart.getTotal());
      }

      elements.items.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('button') as HTMLButtonElement;
        if (!btn) return;
        const { action, id } = btn.dataset;
        const idNum = id !== undefined ? Number(id) : NaN;
        if (Number.isNaN(idNum)) return;
        const item = Cart.getItems().find(i => i.id === idNum);
        if (!item) return;
        try {
          if (action === 'inc') Cart.updateQuantity(idNum, item.quantity + 1);
          if (action === 'dec' && item.quantity > 1) Cart.updateQuantity(idNum, item.quantity - 1);
          if (action === 'remove') Cart.removeItem(idNum);
          renderCart();
        } catch (err) {
          alert((err as Error).message);
        }
      });

      elements.items.addEventListener('focus', (e) => {
        if ((e.target as HTMLElement).tagName === 'INPUT') {
          (e.target as HTMLInputElement).select();
        }
      }, true);

      elements.items.addEventListener('blur', (e) => {
        const target = e.target as HTMLElement;
        if (target.tagName !== 'INPUT') return;
        const input = target as HTMLInputElement;
        const value = parseInt(input.value) || 1;
        const idNum = input.dataset.id !== undefined ? Number(input.dataset.id) : NaN;
        if (!Number.isNaN(idNum)) {
          try {
            Cart.updateQuantity(idNum, value);
            renderCart();
          } catch (err) {
            alert((err as Error).message);
            renderCart();
          }
        }
      }, true);

      elements.form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const items = Cart.getItems().map(item => ({
          edition_id: Number(item.id),
          quantity: item.quantity
        }));
        const email = elements.emailInput.value.trim();
        if (items.length === 0) return;
        if (!email) {
          alert('Please enter your email address.');
          return;
        }
        try {
          elements.checkout.disabled = true;
          const rootEl = document.querySelector<HTMLElement>('[data-api-url]')!;
          const apiUrl = rootEl?.dataset.apiUrl || '';
          const currency = (rootEl?.dataset.currency || 'gbp').toUpperCase();
          const res = await fetch(`${apiUrl}/api/checkout`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items, email, currency })
          });
          if (res.status === 404) {
            alert('The page you requested was not available on the server.');
            return;
          }
          const data = await res.json();
          if (!res.ok) {
            alert(data?.message || `Checkout failed (${res.status})`);
            return;
          }
          if (data?.url) {
            window.location.href = data.url;
          } else {
            alert('Checkout session not returned.');
          }
        } catch (err) {
          alert('Network error. Please try again.');
        } finally {
          elements.checkout.disabled = false;
        }
      });

      renderCart();
      window.addEventListener('cart-updated', renderCart);
    }

    document.addEventListener('astro:page-load', setupCheckoutPage);
  </script>
</BaseLayout>
