---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORT_EMAIL } from '../../lib/constants';
import { locales, defaultLocale, useTranslations, getLocalePath } from '../../lib/i18n';

export function getStaticPaths() {
  return locales
    .filter(l => l !== defaultLocale)
    .map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
---

<BaseLayout title={t('failure_title')}>
  <div class="max-w-2xl mx-auto py-12 text-center">
    <div class="mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 mx-auto text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>

    <h1 class="text-3xl font-bold mb-4">{t('failure_header')}</h1>

    <p class="text-lg opacity-70 mb-8">
      {t('failure_body')}
    </p>

    <div class="space-y-4">
      <p class="text-sm opacity-60">
        {t('failure_subtext')}
      </p>

      <div class="flex gap-4 justify-center flex-wrap">
        <a href={getLocalePath(lang, '/checkout')} data-astro-prefetch class="btn btn-primary">
          {t('failure_try_again')}
        </a>
        <a href={getLocalePath(lang, '/catalog')} data-astro-prefetch class="btn btn-outline">
          {t('failure_continue')}
        </a>
      </div>

      <p class="text-sm opacity-60 mt-8">
        {t('failure_help')} <a href={`mailto:${SUPPORT_EMAIL}`} class="text-primary hover:text-primary-focus">{SUPPORT_EMAIL}</a>
      </p>
    </div>
  </div>
</BaseLayout>
