---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <div class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
    <div class="w-full">
      <div class="grid grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-2 lg:items-center">
        <div class="lg:pr-8">
          <div class="lg:max-w-lg">
            <h2 class="text-base/7 font-semibold text-primary">eBooks done right</h2>
            <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty sm:text-5xl">Longhouse Press</p>
            <p class="mt-6 text-lg/8 opacity-70">Carefully crafted digital books for modern readers.</p>
            <dl class="mt-10 space-y-8 text-base/7 opacity-60">
              <div class="relative pl-9">
                <dt class="inline font-semibold opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" class="absolute top-1 left-1 size-5 text-primary">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                  </svg>
                  Thoughtfully curated.
                </dt>
                <dd class="inline">Our catalog blends battle-worn classics alongside exceptional contemporary writing. We only publish what we would like to read ourselves.</dd>
              </div>
              <div class="relative pl-9">
                <dt class="inline font-semibold opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" class="absolute top-1 left-1 size-5 text-primary">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 1 1 9 0v3.75M3.75 21.75h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H3.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                  </svg>
                  Yours to own.
                </dt>
                <dd class="inline">Our eBooks come with zero DRM: every edition you buy is yours to own, read, modify, delete, and share with friends. We treat our customers with respect, not suspicion.</dd>
              </div>
              <div class="relative pl-9">
                <dt class="inline font-semibold opacity-100">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" class="absolute top-1 left-1 size-5 text-primary">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5h3m-6.75 2.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-15a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 4.5v15a2.25 2.25 0 0 0 2.25 2.25Z" />
                  </svg>
                  Digital first.
                </dt>
                <dd class="inline">Instead of treating eBooks as an afterthought to print editions, we use modern eBook standards to deliver a thoughtfully designed reading experience that makes full use of your device’s capabilities.</dd>
              </div>
            </dl>
            <div class="mt-10">
              <a href="/catalog" class="btn btn-primary">Browse our books</a>
            </div>
          </div>
        </div>
        <div class="flex justify-center lg:justify-end">
          <figure>
            <img
              src="/hero.png"
              alt="Product screenshot"
              class="w-full max-w-none rounded-xl lg:max-w-2xl"
            />
            <figcaption class="mt-2 text-sm opacity-70 text-center">
              Actual rendering of <a href="/books/moliere-don-juan" class="text-primary underline">Don Juan by Molière</a> on different devices
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
