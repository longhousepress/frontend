---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
---

<BaseLayout title="Catalog">
  <div class="py-6">
    <div class="max-w-7xl mx-auto mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <h2 class="text-2xl font-semibold">Catalog</h2>
      </div>
      
      <label class="floating-label sm:min-w-64 relative">
        <input type="text" placeholder="Search books..." class="input input-sm pr-10" />
        <span>Search</span>
        <kbd class="kbd kbd-sm absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none">/</kbd>
      </label>
    </div>

    <div class="max-w-7xl mx-auto">
      <!-- Centered responsive grid. Cards are centered inside each grid cell. -->
      <div class="grid gap-8 justify-items-center grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        <BookCard title="Pride and Prejudice" author="Jane Austen" price="£2.99" img="/cover003.jpg" />
        <BookCard title="Moby Dick" author="Herman Melville" price="£3.50" img="/cover008.jpg" />
        <BookCard title="Frankenstein" author="Mary Shelley" price="£2.50" img="/cover013.jpg" />
        <BookCard title="The Odyssey" author="Homer" price="£3.75" img="/cover019.jpg" />
        <BookCard title="Little Women" author="Louisa May Alcott" price="£2.25" img="/cover020.jpg" />
        <BookCard title="Dracula" author="Bram Stoker" price="£2.80" img="/cover023.jpg" />
        <BookCard title="Great Expectations" author="Charles Dickens" price="£3.10" img="/cover030.jpg" />
        <BookCard title="Selected Poems" author="Various" price="£1.99" img="/cover080-cropped.jpg" />
        <BookCard title="Walden" author="Henry David Thoreau" price="£2.40" img="/cover050.jpg" />
        <BookCard title="Leaves of Grass" author="Walt Whitman" price="£3.00" img="/cover052.jpg" />
      </div>
    </div>

    <div class="flex justify-center mt-8">
      <div class="join">
        <button class="join-item btn btn-disabled">«</button>
        <button class="join-item btn">Page 1</button>
        <button class="join-item btn">»</button>
      </div>
    </div>
  </div>
</BaseLayout>