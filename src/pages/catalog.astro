---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import { SELECTED_CURRENCY } from '../lib/constants';
import { getPriceForCurrency, formatPrice } from '../lib/utils';
import type { Book } from '../types/book';

// Import all cover images from the nested assets/<book-slug>/cover structure
// This allows Astro to optimize images at build time
const coverImages = import.meta.glob<{ default: ImageMetadata }>('../assets/*/cover/*');

// Helper function to get the optimized image for a cover filename
// Backend provides just the filename (e.g., "book-slug.jpg")
// Assets are stored at ../assets/<book-slug>/cover/<filename>
async function getCoverImage(coverFilename: string, bookSlug: string) {
  if (!coverFilename) return coverFilename;

  // Exact path only - no fuzzy matching, no fallbacks
  const exactPath = `../assets/${bookSlug}/cover/${coverFilename}`;
  const imageModule = coverImages[exactPath];
  
  if (imageModule) {
    const image = await imageModule();
    return image.default;
  }

  // Not found in optimized assets, return original path for fallback
  return coverFilename;
}

// Fetch ALL books from API at build time (no language filtering - backend returns all editions)
// Use BUILD_API_URL for build-time fetches (must be full URL), PUBLIC_API_URL for client-side (can be empty for same-origin)
const BUILD_API_URL = import.meta.env.BUILD_API_URL || import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
const response = await fetch(`${BUILD_API_URL}/api/books`);
const booksRaw: Book[] = await response.json();

// Flatten all editions from all books that have pricing in the selected currency
// This will show ALL editions (across all languages/formats) that have GBP pricing
// When a book has multiple editions (e.g., English and Korean), both will appear if both have GBP prices
// TODO: When currency selector is added:
//   1. Replace SELECTED_CURRENCY with a reactive currency state/prop
//   2. The filtering logic below will automatically work with the new currency
//   3. May want to add additional filtering for language/format preferences
const booksWithPaths = (booksRaw || [])
  .flatMap((book: Book) => {
    // Get all editions that have a price in the selected currency
    return (book.editions || [])
      .map((edition: any) => {
        // Get price for selected currency from the prices array
        const price = edition.prices ? getPriceForCurrency(edition.prices, SELECTED_CURRENCY) : null;

        // Skip this edition if no price available for selected currency
        // This means books without GBP pricing won't appear in the catalog at all
        if (price === null) {
          return null;
        }

        return {
          id: edition.id,
          title: edition.title,
          author: edition.author_name,
          price: price,
          coverPath: edition.cover, // Store original path for image lookup
          description: edition.description,
          book_slug: book.book_slug,
          categories: edition.categories || book.categories || [],
          format: edition.format || 'eBook',
          language: edition.language || null,
          page_count: edition.page_count || null,
          translator: edition.translator_name || null,
          publication_date: edition.publication_date || null,
          isbn: edition.isbn || null,
          original: edition.original || false,
        };
      })
      .filter((edition: any) => edition !== null);
  });

// Load optimized cover images for all books and sort by original first, then publication_date
const books = (await Promise.all(
  booksWithPaths.map(async (book: any) => ({
    ...book,
    cover: await getCoverImage(book.coverPath, book.book_slug),
  }))
)).sort((a, b) => {
  // Sort by original first (true before false)
  if (a.original !== b.original) {
    return a.original ? -1 : 1;
  }
  // Then sort by publication_date (most recent first, nulls last)
  if (a.publication_date && b.publication_date) {
    return b.publication_date.localeCompare(a.publication_date);
  }
  if (a.publication_date) return -1;
  if (b.publication_date) return 1;
  return 0;
});

// Format price helper for server-side rendering (500 -> £5.00)


// Extract all unique categories from books
const allCategories = Array.from(
  new Set(
    books.flatMap((book: any) => book.categories || [])
  )
).sort() as string[];
---

<BaseLayout title="Catalog">
  <div class="py-6">
    <!-- Centered Title -->
    <div class="max-w-7xl mx-auto mb-6 text-center">
      <h2 class="text-2xl font-semibold">Catalog</h2>
    </div>

    <!-- Search with Filter -->
    <div class="max-w-7xl mx-auto mb-6">
      <!-- Filter and Search Container -->
      <div class="flex justify-between items-start sm:items-center flex-col sm:flex-row gap-4 sm:gap-0">
        <!-- Filter Button & Expandable Panel Container -->
        <div class="relative w-full sm:w-auto">
          <div class="flex items-center sm:block">
            <!-- Filter Button -->
            <button
              id="filter-toggle"
              class="btn btn-sm btn-square h-8 min-h-8 shrink-0 relative z-10"
              aria-label="Toggle filters"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
              </svg>
            </button>
          </div>

          <!-- Expandable Filter Panel -->
          <div
            id="filter-panel"
            class="filter-panel overflow-hidden transition-all duration-300 ease-in-out"
          >
            <div class="filter-panel-content bg-base-300 p-3 flex flex-col sm:flex-row sm:items-center gap-3">
            <!-- Genre Filter -->
            <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
              <span class="text-xs font-medium whitespace-nowrap">Genre</span>
              <span class="hidden sm:inline text-xs opacity-30">|</span>
              <div class="flex items-center gap-3 flex-wrap sm:flex-nowrap">
                {allCategories.map((category: string) => (
                  <label class="flex items-center gap-1 cursor-pointer whitespace-nowrap">
                    <input
                      type="checkbox"
                      class="checkbox checkbox-xs checkbox-primary genre-filter rounded-sm"
                      value={category}
                    />
                    <span class="text-xs">{category}</span>
                  </label>
                ))}
              </div>
            </div>


          </div>
        </div>
      </div>

      <!-- Search Input with Keyboard Hint -->
      <label class="floating-label relative w-full sm:w-[calc((100%-2rem)/2)] md:w-[calc((100%-4rem)/3)] lg:w-[calc((100%-6rem)/4)] xl:w-[calc((100%-8rem)/5)]">
        <input type="text" id="search-input" placeholder="Search books..." class="input input-sm pr-10 w-full" />
        <span>Search</span>
        <kbd id="search-kbd" class="kbd kbd-sm absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none">/</kbd>
      </label>
    </div>
    </div>

    <!-- Books Grid & No Results Message -->
    <div class="max-w-7xl mx-auto">
      <!-- Server-rendered book cards -->
      <div id="books-grid" class="grid gap-8 justify-items-center grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        {books.map((edition: any) => (
          <div
            class="book-item w-full max-w-[240px]"
            data-title={edition.title.toLowerCase()}
            data-author={edition.author.toLowerCase()}
            data-categories={JSON.stringify(edition.categories || [])}
            data-price={(edition.price / 100).toFixed(2)}
          >
            <BookCard
              title={edition.title}
              author={edition.author}
              price={formatPrice(edition.price)}
              img={edition.cover}
              href={`/books/${edition.book_slug}`}
            />
          </div>
        ))}
      </div>

      <!-- No Results Message -->
      <div id="no-results" class="hidden text-center py-12">
        <p class="text-lg opacity-70">No books found matching your search.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Mobile: expand downward and push content */
  .filter-panel {
    width: 100%;
    max-height: 0;
    opacity: 0;
    margin-top: 0.5rem;
    border-radius: 0.5rem;
    transition: max-height 0.3s ease-in-out, opacity 0.3s ease-in-out;
  }

  .filter-panel.open {
    max-height: 500px;
    opacity: 1;
  }

  .filter-panel-content {
    border-radius: 0.5rem;
  }

  /* Desktop: expand to the right and position absolutely */
  @media (min-width: 640px) {
    .filter-panel {
      position: absolute;
      top: 0;
      left: 28px;
      width: 0;
      max-height: none;
      height: 2rem;
      margin-top: 0;
      border-radius: 0 0.5rem 0.5rem 0;
      display: flex;
      align-items: center;
      opacity: 0;
      transition: width 0.3s ease-in-out, opacity 0.3s ease-in-out;
    }

    .filter-panel.open {
      width: auto;
      max-height: none;
      opacity: 1;
    }

    .filter-panel-content {
      white-space: nowrap;
      height: 2rem;
      border-radius: 0 0.5rem 0.5rem 0;
      padding-left: 0.75rem;
      padding-right: 0.75rem;
      display: flex;
      flex-direction: row;
      align-items: center;
    }
  }


</style>

<!-- Catalog page scripts -->
<script>
  function setupSearchShortcuts() {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchKbd = document.getElementById('search-kbd');

    // Early return if essential elements don't exist (not on catalog page)
    if (!searchInput) return;

    searchInput.addEventListener('focus', () => {
      if (searchKbd) searchKbd.textContent = 'Esc';
    });

    searchInput.addEventListener('blur', () => {
      if (searchKbd) searchKbd.textContent = '/';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement && !['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) {
        e.preventDefault();
        searchInput.focus();
      }

      if (e.key === 'Escape' && document.activeElement === searchInput) {
        searchInput.blur();
      }
    });
  }

  function setupFilterToggle() {
    const filterToggle = document.getElementById('filter-toggle');
    const filterPanel = document.getElementById('filter-panel') as HTMLElement;
    let isFilterOpen = false;

    // Early return if essential elements don't exist (not on catalog page)
    if (!filterToggle || !filterPanel) return;

    filterToggle.addEventListener('click', () => {
      isFilterOpen = !isFilterOpen;

      if (isFilterOpen) {
        filterPanel.classList.add('open');
      } else {
        filterPanel.classList.remove('open');
      }
    });

    // Close filter panel when clicking outside
    document.addEventListener('click', (e) => {
      if (isFilterOpen &&
          !filterPanel.contains(e.target as Node) &&
          !filterToggle.contains(e.target as Node)) {
        isFilterOpen = false;
        filterPanel.classList.remove('open');
      }
    });
  }

  function setupFiltering() {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const booksGrid = document.getElementById('books-grid');
    const noResults = document.getElementById('no-results');
    const bookItems = document.querySelectorAll('.book-item');
    const genreFilters = document.querySelectorAll('.genre-filter') as NodeListOf<HTMLInputElement>;

    // Early return if essential elements don't exist (not on catalog page)
    if (!searchInput || !booksGrid) return;

    function filterBooks() {
      const query = searchInput.value.toLowerCase().trim();

      // Get selected genres
      const selectedGenres = Array.from(genreFilters)
        .filter(checkbox => checkbox.checked)
        .map(checkbox => checkbox.value);

      let visibleCount = 0;

      bookItems.forEach(item => {
        const title = (item as HTMLElement).dataset.title || '';
        const author = (item as HTMLElement).dataset.author || '';
        const categoriesStr = (item as HTMLElement).dataset.categories || '[]';
        const categories = JSON.parse(categoriesStr);

        // Check if matches search query
        const matchesSearch = !query || title.includes(query) || author.includes(query);

        // Check if matches genre filter (if any selected)
        const matchesGenre = selectedGenres.length === 0 ||
          selectedGenres.some(genre => categories.includes(genre));

        const matches = matchesSearch && matchesGenre;

        (item as HTMLElement).style.display = matches ? '' : 'none';
        if (matches) visibleCount++;
      });

      if (visibleCount === 0) {
        booksGrid?.classList.add('hidden');
        noResults?.classList.remove('hidden');
      } else {
        booksGrid?.classList.remove('hidden');
        noResults?.classList.add('hidden');
      }
    }

    searchInput?.addEventListener('input', filterBooks);
    genreFilters.forEach(checkbox => {
      checkbox.addEventListener('change', filterBooks);
    });
  }

  function initializeCatalogPage() {
    setupSearchShortcuts();
    setupFilterToggle();
    setupFiltering();
  }

  // Run on initial load and after view transitions
  document.addEventListener('astro:page-load', initializeCatalogPage);
</script>
