---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000';
  const response = await fetch(`${API_URL}/api/books?lang=eng`);
  const books = await response.json();

  return await Promise.all(
    books.map(async (book: any) => {
      const detailResponse = await fetch(`${API_URL}/api/books/${book.book_slug}`);
      const bookData = await detailResponse.json();
      return {
        params: { slug: book.book_slug },
        props: { bookData },
      };
    })
  );
}

const { bookData } = Astro.props;
const defaultEdition = bookData.editions[0];
const formatPrice = (price: number) => `£${(price / 100).toFixed(2)}`;
const samplePages = bookData.sample_pages || defaultEdition.sample_pages || [];
---

<BaseLayout title={`${defaultEdition.title} - ${defaultEdition.author_name}`}>
  <div class="py-6">
    <div class="grid sm:grid-cols-2 gap-8 mb-8 items-end">
      <div class="flex flex-col items-center sm:items-start justify-end" style="height: calc(320px * 9 / 6);">
        <img
          src={defaultEdition.cover}
          alt={`Cover of ${defaultEdition.title} by ${defaultEdition.author_name}`}
          class="rounded-lg shadow-2xl mb-4"
          style="width: 320px; max-width: 320px; aspect-ratio: 6 / 9; object-fit: contain;"
        />
        {samplePages.length > 0 && (
          <button 
            id="read-sample-btn" 
            class="btn btn-outline btn-sm w-full max-w-[320px]"
            data-sample-pages={JSON.stringify(samplePages)}
          >
            Read a sample
          </button>
        )}
      </div>


      <div class="flex flex-col" style="height: calc(320px * 9 / 6);">

        <div class="shrink-0">
          <details class="metadata-details mb-4">
            <summary class="flex items-center gap-2 cursor-pointer list-none mb-4">
              <h1 class="font-bold">{defaultEdition.title}</h1>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="opacity-50 hover:opacity-100 transition-all duration-200 metadata-arrow">
                <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
              </svg>
            </summary>


            <div class="pb-4">
              <div class="space-y-2 text-sm">
                {defaultEdition.page_count && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Pages:</span>
                    <span class="font-medium">{defaultEdition.page_count}</span>
                  </div>
                )}
                {defaultEdition.language && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Language:</span>
                    <span class="font-medium">{defaultEdition.language}</span>
                  </div>
                )}
                {defaultEdition.translator && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Translator:</span>
                    <span class="font-medium">{defaultEdition.translator}</span>
                  </div>
                )}
                {bookData.year_published && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Originally Published:</span>
                    <span class="font-medium">{bookData.year_published}</span>
                  </div>
                )}
                {defaultEdition.publication_date && (
                  <div class="flex justify-between">
                    <span class="opacity-70">This Edition:</span>
                    <span class="font-medium">{defaultEdition.publication_date}</span>
                  </div>
                )}
                {defaultEdition.isbn && (
                  <div class="flex justify-between">
                    <span class="opacity-70">ISBN:</span>
                    <span class="font-medium">{defaultEdition.isbn}</span>
                  </div>
                )}
              </div>
              <div class="divider my-4"></div>
            </div>
          </details>

          {bookData.author_bio ? (
            <details class="author-details mb-6">
              <summary class="flex items-center gap-2 cursor-pointer list-none">
                <p class="opacity-70">by {defaultEdition.author_name}</p>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="opacity-50 hover:opacity-100 transition-all duration-200 author-arrow">
                  <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                </svg>
              </summary>


              <div class="mt-4 pb-0">
                <p class="text-sm leading-relaxed opacity-80">{bookData.author_bio}</p>
                <div class="divider my-0"></div>
              </div>
            </details>
          ) : (
            <p class="opacity-70 mb-6">by {defaultEdition.author_name}</p>
          )}
        </div>


        <div class="flex-1 mb-6 relative overflow-hidden" id="description-wrapper">
          <div class="h-full overflow-y-auto pr-2 description-scroll relative" id="description-container">
            {defaultEdition.description && (
              <div class="mb-6">
                <p class="text-sm leading-relaxed opacity-80">{defaultEdition.description}</p>
              </div>
            )}
          </div>

          <div class="description-fade pointer-events-none"></div>

          <button class="description-scroll-btn" id="scroll-indicator" aria-label="Scroll down">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
            </svg>
          </button>
        </div>


        <div class="shrink-0">

          <div class="grid grid-cols-2 gap-4 mb-6">

            <div class="flex gap-2 items-center">
              <button class="btn btn-outline btn-sm">eBook</button>
              <div class="custom-tooltip">
                <button class="btn btn-dash btn-sm" disabled>Paperback</button>
                <span class="tooltip-text">Not currently available</span>
              </div>
              <div class="custom-tooltip">
                <button class="btn btn-dash btn-sm" disabled>Hardcover</button>
                <span class="tooltip-text">Not currently available</span>
              </div>
            </div>


            <div class="flex items-center justify-end">
              <div class="text-2xl leading-8 font-bold text-primary">
                {formatPrice(defaultEdition.price)}
              </div>
            </div>
          </div>


          <button
            id="add-to-cart-btn"
            data-book-id={defaultEdition.id}
            data-book-title={defaultEdition.title}
            data-book-price={defaultEdition.price}
            data-book-cover={defaultEdition.cover}
            data-book-slug={bookData.book_slug}
            data-book-format={defaultEdition.format || 'eBook'}
            data-book-language={defaultEdition.language || 'English'}
            class="btn btn-primary btn-sm btn-block"
          >
            Add to cart
          </button>
        </div>
      </div>
    </div>




    {bookData.categories && bookData.categories.length > 0 && (
      <>
        <div class="divider"></div>
        <div>
          <h2 class="text-2xl font-bold mb-3">Categories</h2>
          <div class="flex flex-wrap gap-2">
            {bookData.categories.map((category: string) => (
              <span class="badge badge-lg">{category}</span>
            ))}
          </div>
        </div>
      </>
    )}
  </div>

  {samplePages.length > 0 && (
  <div id="sample-modal" class="sample-modal hidden">

    <div class="sample-modal-backdrop"></div>
    

    <div class="sample-modal-content">

      <div class="sample-control-panel bg-base-100 flex items-center justify-between px-4 py-1 rounded-t-lg">
        <span class="text-sm opacity-70">
          <span class="font-medium">{defaultEdition.title}</span> — Sample — <span id="page-indicator">Page 1 of 4</span>
        </span>
        <button id="close-modal-btn" class="btn btn-sm btn-ghost">✕</button>
      </div>
      

      <div class="flex justify-center bg-white p-4">
        <img id="page-image" src="" alt="Book sample page" class="max-h-[75vh] w-auto" />
      </div>
      

      <div class="sample-control-panel bg-base-100 flex items-center justify-between gap-4 px-4 py-1 rounded-b-lg">
        <button id="prev-page-btn" class="btn btn-xs" disabled>
          ←
        </button>
        <input 
          id="page-slider" 
          type="range" 
          min="0" 
          max="3" 
          value="0" 
          class="range range-xs flex-1 opacity-30"
        />
        <button id="next-page-btn" class="btn btn-xs">
          →
        </button>
      </div>
    </div>
  </div>
  )}

  <style>
    .metadata-details[open] .metadata-arrow,
    .author-details[open] .author-arrow {
      transform: rotate(180deg);
    }

    .metadata-details summary::-webkit-details-marker,
    .author-details summary::-webkit-details-marker {
      display: none;
    }

    .description-scroll {
      z-index: 1;
    }

    .custom-tooltip {
      position: relative;
      display: inline-flex;
      align-items: center;
    }

    .custom-tooltip .tooltip-text {
      visibility: hidden;
      opacity: 0;
      background-color: rgba(0, 0, 0, 0.9);
      color: #fff;
      text-align: center;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.75rem;
      white-space: nowrap;

      /* Position below button */
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      margin-top: 4px;
      z-index: 20;

      transition: opacity 0.2s, visibility 0.2s;
    }

    .custom-tooltip:hover .tooltip-text {
      visibility: visible;
      opacity: 1;
    }


    .sample-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .sample-modal.hidden {
      display: none;
    }

    .sample-modal-backdrop {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.7);
      cursor: pointer;
      z-index: 1;
    }

    .sample-modal-content {
      position: relative;
      max-width: 90vw;
      max-height: 90vh;
      z-index: 100;
      display: flex;
      flex-direction: column;
    }

    .sample-control-panel {
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
    }

    #page-image {
      display: block;
      object-fit: contain;
    }
  </style>

  <script>
    const container = document.getElementById('description-container');
    const wrapper = document.getElementById('description-wrapper');
    const scrollBtn = document.getElementById('scroll-indicator');

    if (container && wrapper && scrollBtn) {
      const checkOverflow = () => {
        const hasOverflow = container.scrollHeight > container.clientHeight;
        wrapper.classList.toggle('has-overflow', hasOverflow);
      };

      checkOverflow();
      window.addEventListener('resize', checkOverflow);

      scrollBtn.addEventListener('click', () => {
        container.scrollBy({ top: 100, behavior: 'smooth' });
      });

      container.addEventListener('scroll', () => {
        const isAtBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 10;
        wrapper.classList.toggle('has-overflow', !isAtBottom && container.scrollHeight > container.clientHeight);
      });
    }

    import { Cart } from '../../lib/cart';
    const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;

    btn?.addEventListener('click', () => {
      Cart.addItem({
        id: Number(btn.dataset.bookId!),
        title: btn.dataset.bookTitle!,
        price: parseInt(btn.dataset.bookPrice!),
        cover: btn.dataset.bookCover,
        slug: btn.dataset.bookSlug,
        format: btn.dataset.bookFormat,
        language: btn.dataset.bookLanguage,
      });


      const originalText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Successfully added';

      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = originalText;
      }, 1000);
    });


    const readSampleBtn = document.getElementById('read-sample-btn');
    const sampleModal = document.getElementById('sample-modal') as HTMLDivElement;
    const closeModalBtn = document.getElementById('close-modal-btn');
    const modalBackdrop = document.querySelector('.sample-modal-backdrop') as HTMLElement;
    const pageImage = document.getElementById('page-image') as HTMLImageElement;
    const prevBtn = document.getElementById('prev-page-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page-btn') as HTMLButtonElement;
    const pageSlider = document.getElementById('page-slider') as HTMLInputElement;

    // Get sample pages from data attribute
    const samplePagesData = readSampleBtn?.getAttribute('data-sample-pages');
    const samplePages: string[] = samplePagesData ? JSON.parse(samplePagesData) : [];
    let currentPageIndex = 0;

    function updateSampleDisplay() {
      if (!pageImage) return;
      
      // Display current page image
      pageImage.src = samplePages[currentPageIndex] || '';
      pageImage.alt = `Book sample page ${currentPageIndex + 1}`;
      
      // Update button states
      const totalPages = samplePages.length;
      prevBtn.disabled = currentPageIndex === 0;
      nextBtn.disabled = currentPageIndex >= totalPages - 1;
      
      // Update slider
      pageSlider.value = currentPageIndex.toString();
      
      // Update page indicator
      const pageIndicator = document.getElementById('page-indicator');
      if (pageIndicator) {
        pageIndicator.textContent = `Page ${currentPageIndex + 1} of ${totalPages}`;
      }
    }

    readSampleBtn?.addEventListener('click', () => {
      if (samplePages.length === 0) return;
      currentPageIndex = 0;
      pageSlider.max = (samplePages.length - 1).toString();
      updateSampleDisplay();
      sampleModal?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    const closeModal = () => {
      sampleModal?.classList.add('hidden');
      document.body.style.overflow = '';
    };

    closeModalBtn?.addEventListener('click', closeModal);
    modalBackdrop?.addEventListener('click', closeModal);

    prevBtn?.addEventListener('click', () => {
      if (currentPageIndex > 0) {
        currentPageIndex--;
        updateSampleDisplay();
      }
    });

    nextBtn?.addEventListener('click', () => {
      if (currentPageIndex < samplePages.length - 1) {
        currentPageIndex++;
        updateSampleDisplay();
      }
    });

    pageSlider?.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      currentPageIndex = parseInt(target.value);
      updateSampleDisplay();
    });


    document.addEventListener('keydown', (e) => {
      if (sampleModal?.classList.contains('hidden')) return;
      
      if (e.key === 'ArrowLeft' && !prevBtn.disabled) {
        e.preventDefault();
        prevBtn.click();
      } else if (e.key === 'ArrowRight' && !nextBtn.disabled) {
        e.preventDefault();
        nextBtn.click();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        closeModal();
      }
    });

  </script>
</BaseLayout>
