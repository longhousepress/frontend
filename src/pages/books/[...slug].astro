---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000';
  const response = await fetch(`${API_URL}/api/books?lang=eng`);
  const books = await response.json();

  // Fetch full details for each book
  const booksWithDetails = await Promise.all(
    books.map(async (book: any) => {
      const detailResponse = await fetch(`${API_URL}/api/books/${book.book_slug}`);
      const bookData = await detailResponse.json();
      return {
        params: { slug: book.book_slug },
        props: { bookData },
      };
    })
  );

  return booksWithDetails;
}

const { bookData } = Astro.props;

// Default to first edition for now (we'll add edition selection UI later)
const defaultEdition = bookData.editions[0];

// Format price helper (500 -> £5.00)
const formatPrice = (price: number) => {
  return `£${(price / 100).toFixed(2)}`;
};
---

<BaseLayout title={`${defaultEdition.title} - ${bookData.author}`}>
  <div class="py-6">
    <!-- Two-column layout: cover left, details right -->
    <div class="grid sm:grid-cols-2 gap-8 mb-8">
      <!-- Left column: Cover image -->
      <div class="flex justify-center sm:justify-start">
        <img
          src={defaultEdition.cover}
          alt={`Cover of ${defaultEdition.title} by ${bookData.author}`}
          class="rounded-lg shadow-2xl"
          style="width: 320px; max-width: 320px; aspect-ratio: 6 / 9; object-fit: contain;"
        />
      </div>

      <!-- Right column: Book details (flex layout with description in middle, buy button at bottom) -->
      <div class="flex flex-col" style="height: calc(320px * 9 / 6);">
        <!-- Top section: Title & Author -->
        <div class="shrink-0">
          <details class="metadata-details mb-4">
            <summary class="flex items-center gap-2 cursor-pointer list-none mb-4">
              <h1 class="font-bold">{defaultEdition.title}</h1>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="opacity-50 hover:opacity-100 transition-all duration-200 metadata-arrow">
                <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
              </svg>
            </summary>

            <!-- Metadata section -->
            <div class="pb-4">
              <div class="space-y-2 text-sm">
                {defaultEdition.page_count && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Pages:</span>
                    <span class="font-medium">{defaultEdition.page_count}</span>
                  </div>
                )}
                {defaultEdition.language && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Language:</span>
                    <span class="font-medium">{defaultEdition.language}</span>
                  </div>
                )}
                {defaultEdition.translator && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Translator:</span>
                    <span class="font-medium">{defaultEdition.translator}</span>
                  </div>
                )}
                {bookData.year_published && (
                  <div class="flex justify-between">
                    <span class="opacity-70">Originally Published:</span>
                    <span class="font-medium">{bookData.year_published}</span>
                  </div>
                )}
                {defaultEdition.publication_date && (
                  <div class="flex justify-between">
                    <span class="opacity-70">This Edition:</span>
                    <span class="font-medium">{defaultEdition.publication_date}</span>
                  </div>
                )}
                {defaultEdition.isbn && (
                  <div class="flex justify-between">
                    <span class="opacity-70">ISBN:</span>
                    <span class="font-medium">{defaultEdition.isbn}</span>
                  </div>
                )}
              </div>
              <div class="divider my-4"></div>
            </div>
          </details>

          {bookData.author_bio ? (
            <details class="author-details mb-6">
              <summary class="flex items-center gap-2 cursor-pointer list-none">
                <p class="opacity-70">by {bookData.author}</p>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="opacity-50 hover:opacity-100 transition-all duration-200 author-arrow">
                  <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                </svg>
              </summary>

              <!-- Author bio box -->
              <div class="mt-4 pb-0">
                <p class="text-sm leading-relaxed opacity-80">{bookData.author_bio}</p>
                <div class="divider my-0"></div>
              </div>
            </details>
          ) : (
            <p class="opacity-70 mb-6">by {bookData.author}</p>
          )}
        </div>

        <!-- Middle section: Scrollable description (flexes to fill space) -->
        <div class="flex-1 mb-6 relative overflow-hidden" id="description-wrapper">
          <div class="h-full overflow-y-auto pr-2 description-scroll relative" id="description-container">
            {defaultEdition.description && (
              <div class="mb-6">
                <p class="text-sm leading-relaxed opacity-80">{defaultEdition.description}</p>
              </div>
            )}
          </div>
          <!-- Fade overlay when content overflows (positioned outside scroll container) -->
          <div class="description-fade pointer-events-none"></div>
          <!-- Scroll indicator arrow (sticky at bottom) -->
          <button class="description-scroll-btn" id="scroll-indicator" aria-label="Scroll down">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
            </svg>
          </button>
        </div>

        <!-- Bottom section: Purchase info (pinned to bottom, aligned with cover) -->
        <div class="shrink-0">
          <!-- Format buttons and Price - 2 column grid -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <!-- Left column: Format buttons -->
            <div class="flex gap-2 items-center">
              <button class="btn btn-outline btn-sm">eBook</button>
              <div class="custom-tooltip">
                <button class="btn btn-dash btn-sm" disabled>Paperback</button>
                <span class="tooltip-text">Not currently available</span>
              </div>
              <div class="custom-tooltip">
                <button class="btn btn-dash btn-sm" disabled>Hardcover</button>
                <span class="tooltip-text">Not currently available</span>
              </div>
            </div>

            <!-- Right column: Price -->
            <div class="flex items-center justify-end">
              <div class="text-2xl leading-8 font-bold text-accent">
                {formatPrice(defaultEdition.price)}
              </div>
            </div>
          </div>

          <!-- Buy button -->
          <button class="btn btn-primary btn-lg btn-block">
            Buy
          </button>
        </div>
      </div>
    </div>



    <!-- Categories section -->
    {bookData.categories && bookData.categories.length > 0 && (
      <>
        <div class="divider"></div>
        <div>
          <h2 class="text-2xl font-bold mb-3">Categories</h2>
          <div class="flex flex-wrap gap-2">
            {bookData.categories.map((category: string) => (
              <span class="badge badge-lg">{category}</span>
            ))}
          </div>
        </div>
      </>
    )}
  </div>

  <style>
    /* Collapsible details - rotate arrow when open */
    .metadata-details[open] .metadata-arrow,
    .author-details[open] .author-arrow {
      transform: rotate(180deg);
    }

    /* Remove default details marker */
    .metadata-details summary::-webkit-details-marker,
    .author-details summary::-webkit-details-marker {
      display: none;
    }

    /* Scroll container stacking */
    .description-scroll {
      z-index: 1;
    }

    /* Custom tooltip */
    .custom-tooltip {
      position: relative;
      display: inline-flex;
      align-items: center;
    }

    .custom-tooltip .tooltip-text {
      visibility: hidden;
      opacity: 0;
      background-color: rgba(0, 0, 0, 0.9);
      color: #fff;
      text-align: center;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.75rem;
      white-space: nowrap;

      /* Position below button */
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      margin-top: 4px;
      z-index: 20;

      transition: opacity 0.2s, visibility 0.2s;
    }

    .custom-tooltip:hover .tooltip-text {
      visibility: visible;
      opacity: 1;
    }
  </style>

  <script>
    // Detect description overflow and show/hide scroll indicator
    const container = document.getElementById('description-container');
    const wrapper = document.getElementById('description-wrapper');
    const scrollBtn = document.getElementById('scroll-indicator');

    if (container && wrapper && scrollBtn) {
      const checkOverflow = () => {
        const hasOverflow = container.scrollHeight > container.clientHeight;
        wrapper.classList.toggle('has-overflow', hasOverflow);
      };

      // Check on load and resize
      checkOverflow();
      window.addEventListener('resize', checkOverflow);

      // Smooth scroll down on button click
      scrollBtn.addEventListener('click', () => {
        container.scrollBy({ top: 100, behavior: 'smooth' });
      });

      // Hide indicator when scrolled to bottom
      container.addEventListener('scroll', () => {
        const isAtBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 10;
        if (isAtBottom) {
          wrapper.classList.remove('has-overflow');
        } else {
          checkOverflow();
        }
      });
    }
  </script>
</BaseLayout>
