---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetadataField from '../../components/book/MetadataField.astro';
import ChevronIcon from '../../components/icons/ChevronIcon.astro';
import type { Book, Edition } from '../../types/book';
import { SELECTED_CURRENCY, DOMAIN, BUSINESS_NAME, PUBLISHER_LOGO_URL } from '../../lib/constants';
import { formatPrice, getUniqueValues, extractSamplePaths, getPriceForCurrency } from '../../lib/utils';

export async function getStaticPaths() {
  // Import all cover images from the nested assets/<book-folder>/cover using Vite's import.meta.glob
  const coverImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/*/cover/*');

  // Helper function to get the optimized image for a cover filename
  // Backend provides just the filename (e.g., "book-slug.jpg")
  // Assets are stored at ../../assets/<book-slug>/cover/<filename>
  async function getCoverImage(coverFilename: string, bookSlug: string) {
    if (!coverFilename) return null;

    // Exact path only - no fuzzy matching, no fallbacks
    const exactPath = `../../assets/${bookSlug}/cover/${coverFilename}`;
    const imageModule = coverImages[exactPath];

    if (imageModule) {
      const image = await imageModule();
      return image.default;
    }

    // Not found in optimized assets
    return null;
  }

  // Fetch ALL books (no language filter - backend returns all editions)
  // Use BUILD_API_URL for build-time fetches (must be full URL), PUBLIC_API_URL for client-side (can be empty for same-origin)
  const BUILD_API_URL = import.meta.env.BUILD_API_URL || import.meta.env.PUBLIC_API_URL || 'http://localhost:8000';
  const response = await fetch(`${BUILD_API_URL}/api/books`);
  const books: Book[] = await response.json();

  return await Promise.all(
    books.map(async (book) => {
      // Load optimized cover for the default edition
      const defaultEdition = book.editions[0];
      const optimizedCover = await getCoverImage(defaultEdition.cover, book.book_slug);

      return {
        params: { slug: book.book_slug },
        props: { bookData: book, optimizedCover },
      };
    })
  );
}

interface Props {
  bookData: Book;
  optimizedCover?: ImageMetadata | null;
}

const { bookData, optimizedCover } = Astro.props;

// Filter editions that have pricing in the selected currency (currently GBP)
// This ensures we only show editions that are actually available for purchase in the selected currency
// TODO: When currency selector is added:
//   1. Replace SELECTED_CURRENCY with a reactive currency state/prop
//   2. This filter will automatically work with the new currency
const editionsWithPricing = bookData.editions.filter(edition =>
  getPriceForCurrency(edition.prices, SELECTED_CURRENCY) !== null
);

// Select the first edition that has pricing in the selected currency
// If no editions have pricing in selected currency, fall back to first edition
// (will display as unavailable with disabled "Add to cart" button)
// TODO: When adding edition selector dropdown, allow user to choose from editionsWithPricing
const defaultEdition: Edition = editionsWithPricing.length > 0
  ? editionsWithPricing[0]
  : bookData.editions[0];

const samplePages = extractSamplePaths(defaultEdition.samples);

// Get price for selected currency (currently GBP)
// Returns null if not available, which triggers "Price not available" display
const gbpPrice = getPriceForCurrency(defaultEdition.prices, SELECTED_CURRENCY);

// Extract unique formats and languages from editions with pricing in selected currency
// These could be used for edition selector dropdowns in the future
// TODO: When currency selector is added:
//   1. These lists will automatically update based on selected currency
//   2. Can use these to populate format/language selector dropdowns
const availableFormats = getUniqueValues(editionsWithPricing.map(e => e.format).filter(Boolean));
const availableLanguages = getUniqueValues(editionsWithPricing.map(e => e.language).filter(Boolean));

// Always use webp format for optimized images
const coverFormat = optimizedCover ? 'webp' : undefined;

// Open Graph metadata
const ogTitle = `${defaultEdition.title} — ${defaultEdition.author_name}`;
const ogDescription = defaultEdition.short_description || undefined;
const ogImageResult = optimizedCover
  ? await getImage({ src: optimizedCover, width: 640, format: 'webp' })
  : null;
const ogImage = ogImageResult ? `https://${DOMAIN}${ogImageResult.src}` : undefined;
const ogUrl = `https://${DOMAIN}/books/${bookData.book_slug}`;

// JSON-LD structured data for search engines
const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: defaultEdition.title,
  author: { '@type': 'Person', 'name': defaultEdition.author_name },
  url: ogUrl,
  image: ogImage,
  description: ogDescription,
  inLanguage: defaultEdition.language,
  publisher: {
    '@type': 'Organization',
    name: BUSINESS_NAME,
    logo: { '@type': 'ImageObject', url: `https://${DOMAIN}${PUBLISHER_LOGO_URL}` },
  },
  ...(defaultEdition.isbn && { isbn: defaultEdition.isbn }),
  ...(defaultEdition.publication_date && { datePublished: defaultEdition.publication_date }),
  ...(defaultEdition.page_count && { numberOfPages: defaultEdition.page_count }),
  ...(gbpPrice !== null && {
    offers: {
      '@type': 'Offer',
      price: gbpPrice,
      priceCurrency: SELECTED_CURRENCY,
      availability: 'https://schema.org/InStock',
      url: ogUrl,
    },
  }),
};
---

<BaseLayout
  title={`${defaultEdition.title} - ${defaultEdition.author_name}`}
  description={ogDescription}
  canonicalUrl={ogUrl}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  ogUrl={ogUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="py-6">
    <!-- Outer wrapper: stacks on mobile, grid on desktop -->
    <div class="flex flex-col sm:grid sm:grid-cols-2 gap-8 mb-8">

      <!-- LEFT COLUMN: sizes the row via cover aspect ratio, read-sample pinned to bottom -->
      <div class="flex flex-col justify-between pt-6 pl-2 sm:min-h-0">
        <div class="pb-4">
          {optimizedCover ? (
            <Image
              src={optimizedCover}
              alt={`Cover of ${defaultEdition.title} by ${defaultEdition.author_name}`}
              widths={[320, 640]}
              sizes="320px"
              format={coverFormat}
              class="rounded-lg shadow-2xl"
              style="width: 320px; max-width: 100%; aspect-ratio: 6 / 9; object-fit: contain;"
            />
          ) : (
            <img
              src={defaultEdition.cover}
              alt={`Cover of ${defaultEdition.title} by ${defaultEdition.author_name}`}
              class="rounded-lg shadow-2xl"
              style="width: 320px; max-width: 100%; aspect-ratio: 6 / 9; object-fit: contain;"
            />
          )}
        </div>
        {samplePages.length > 0 ? (
          <button
            id="read-sample-btn"
            class="btn btn-outline btn-sm w-full max-w-[320px]"
            data-sample-pages={JSON.stringify(samplePages)}
            data-book-slug={bookData.book_slug}
          >
            Read a sample
          </button>
        ) : (
          <div></div>
        )}
      </div>

      <!-- RIGHT COLUMN: static on mobile, absolute positioning on desktop -->
      <div class="relative sm:min-h-0">
      <div class="static sm:absolute sm:inset-0 flex flex-col sm:overflow-hidden">

        <div class="pt-6">
          <div class="metadata-section mb-4">
            <div class="flex items-center gap-2 cursor-pointer mb-4" id="metadata-toggle">
              <h1 class="font-bold">{defaultEdition.title}</h1>
              <span class="metadata-arrow opacity-50 hover:opacity-100 transition-all duration-200">▼</span>
            </div>

            <div class="metadata-content hidden">
              <div class="pb-4">
                <div class="space-y-2 text-sm">
                  <MetadataField
                    label="Cover"
                    value={[
                      defaultEdition.cover_name,
                      defaultEdition.cover_artist ? `by ${defaultEdition.cover_artist}` : null
                    ].filter(Boolean).join(' ')}
                  />
                  <MetadataField label="Pages" value={defaultEdition.page_count} />
                  <MetadataField label="Language" value={defaultEdition.language} />
                  <MetadataField label="Translator" value={defaultEdition.translator_name} />
                  <MetadataField label="Originally Published" value={bookData.original_publication_year} />
                  <MetadataField label="Original Language" value={bookData.original_language} />
                  <MetadataField label="This Edition" value={defaultEdition.publication_date ? new Date(defaultEdition.publication_date).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' }) : null} />
                  <MetadataField label="ISBN" value={defaultEdition.isbn} />
                </div>
                <div class="divider my-4"></div>
              </div>
            </div>
          </div>

          {defaultEdition.author_bio ? (
            <div class="author-section mb-6">
              <div class="flex items-center gap-2 cursor-pointer" id="author-toggle">
                <p class="opacity-70">by {defaultEdition.author_name}</p>
                <span class="author-arrow opacity-50 hover:opacity-100 transition-all duration-200">▼</span>
              </div>

              <div class="author-content hidden">
                <div class="mt-4 pb-0">
                  <p class="text-sm leading-relaxed opacity-80">{defaultEdition.author_bio}</p>
                  <div class="divider my-0"></div>
                </div>
              </div>
            </div>
          ) : (
            <p class="opacity-70 mb-6">by {defaultEdition.author_name}</p>
          )}
        </div>


        <div class="flex-1 mb-6 min-h-0 flex flex-col">
          {defaultEdition.description && (
            <div class="text-sm leading-relaxed opacity-80 overflow-auto flex-1">
              <span id="description-text" set:html={defaultEdition.description}></span>
              <button class="text-primary hidden" id="read-more-btn">… Read more</button>
            </div>
          )}
        </div>


        <div class="shrink-0">

          <div class="grid grid-cols-2 gap-4 mb-6">

            <div class="flex gap-2 items-end">
              <div class="flex flex-col gap-1">
                <label class="text-xs opacity-70">Format</label>
                <select class="select select-sm w-24" disabled={availableFormats.length <= 1}>
                  {availableFormats.map((format: string) => (
                    <option value={format} selected={format === defaultEdition.format}>
                      {format}
                    </option>
                  ))}
                </select>
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-xs opacity-70">Language</label>
                <select class="select select-sm w-24" disabled={availableLanguages.length <= 1}>
                  {availableLanguages.map((language: string) => (
                    <option value={language} selected={language === defaultEdition.language}>
                      {language}
                    </option>
                  ))}
                </select>
              </div>
            </div>


            <div class="flex items-center justify-end">
              <div class="text-2xl leading-8 font-bold text-primary">
                {gbpPrice !== null ? formatPrice(gbpPrice) : 'Price not available'}
              </div>
            </div>
          </div>


          <div class="flex w-full flex-col lg:flex-row">
            <button
              id="add-to-cart-btn"
              data-book-id={defaultEdition.id}
              data-book-title={defaultEdition.title}
              data-book-price={gbpPrice}
              data-book-cover={defaultEdition.cover}
              data-book-slug={bookData.book_slug}
              data-book-format={defaultEdition.format || 'eBook'}
              data-book-language={defaultEdition.language || 'English'}
              class="btn btn-outline btn-lg grow"
              disabled={gbpPrice === null}
            >
              {gbpPrice !== null ? 'Add to cart' : 'Not available in GBP'}
            </button>
            <div class="divider lg:divider-horizontal"></div>
            <button
              id="checkout-btn"
              data-book-id={defaultEdition.id}
              data-book-title={defaultEdition.title}
              data-book-price={gbpPrice}
              data-book-cover={defaultEdition.cover}
              data-book-slug={bookData.book_slug}
              data-book-format={defaultEdition.format || 'eBook'}
              data-book-language={defaultEdition.language || 'English'}
              class="btn btn-primary btn-lg grow"
              disabled={gbpPrice === null}
            >
              Buy now
            </button>
          </div>
        </div>
      </div>
      </div>
    </div>




    {bookData.categories && bookData.categories.length > 0 && (
      <>
        <div class="divider"></div>
        <div>
          <h2 class="text-2xl font-bold mb-3">Categories</h2>
          <div class="flex flex-wrap gap-2">
            {bookData.categories.map((category) => (
              <span class="badge badge-lg">{category}</span>
            ))}
          </div>
        </div>
      </>
    )}
  </div>

  {samplePages.length > 0 && (
  <div id="sample-modal" class="sample-modal hidden">

    <div class="sample-modal-backdrop"></div>

    <div class="sample-modal-content">

      <div class="sample-control-panel bg-base-100 flex items-center justify-between px-4 py-1 rounded-t-lg">
        <span class="text-sm opacity-70">
          <span class="font-medium">{defaultEdition.title}</span> — Sample — <span id="page-indicator">Page 1 of 4</span>
        </span>
        <button id="close-modal-btn" class="btn btn-sm btn-ghost">✕</button>
      </div>


      <div class="flex justify-center bg-white p-4">
        <img id="page-image" src="" alt="Book sample page" class="max-h-[75vh] w-auto" loading="lazy" />
      </div>


      <div class="sample-control-panel bg-base-100 flex items-center justify-between gap-4 px-4 py-1 rounded-b-lg">
        <button id="prev-page-btn" class="btn btn-xs" disabled>
          ←
        </button>
        <input
          id="page-slider"
          type="range"
          min="0"
          max="3"
          value="0"
          class="range range-xs flex-1 opacity-30"
        />
        <button id="next-page-btn" class="btn btn-xs">
          →
        </button>
      </div>
    </div>
  </div>
  )}

  <style>
    .metadata-arrow,
    .author-arrow {
      display: inline-block;
      transition: transform 0.2s;
      font-size: 12px;
      line-height: 1;
    }

    .metadata-arrow.open,
    .author-arrow.open {
      transform: rotate(180deg);
    }

    .custom-tooltip {
      position: relative;
      display: inline-flex;
      align-items: center;
    }

    .custom-tooltip .tooltip-text {
      visibility: hidden;
      opacity: 0;
      background-color: rgba(0, 0, 0, 0.9);
      color: #fff;
      text-align: center;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.75rem;
      white-space: nowrap;

      /* Position below button */
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      margin-top: 4px;
      z-index: 20;

      transition: opacity 0.2s, visibility 0.2s;
    }

    .custom-tooltip:hover .tooltip-text {
      visibility: visible;
      opacity: 1;
    }


    .sample-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    @media (max-width: 768px) {
      .sample-modal {
        padding: 0;
        flex-direction: column;
        justify-content: center;
      }
    }

    .sample-modal.hidden {
      display: none;
    }

    .sample-modal-backdrop {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.7);
      cursor: pointer;
      z-index: 1;
    }

    .sample-modal-content {
      position: relative;
      max-width: 90vw;
      max-height: 90vh;
      z-index: 100;
      display: flex;
      flex-direction: column;
    }

    @media (max-width: 768px) {
      .sample-modal-content {
        max-width: 100%;
        width: 100%;
        max-height: 90vh;
        height: 90vh;
        border-radius: 0;
      }
    }

    .sample-control-panel {
      box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.1);
    }

    @media (max-width: 768px) {
      .sample-control-panel {
        min-height: 3.5rem;
      }

      .sample-control-panel #close-modal-btn {
        font-size: 2rem;
        height: 100%;
        min-height: 3.5rem;
        padding: 0 1.5rem;
      }

      .sample-control-panel button {
        height: 100%;
        min-height: 3.5rem;
        padding: 0 1rem;
      }
    }

    #page-image {
      display: block;
      object-fit: contain;
    }
  </style>

  <script>
    import { Cart } from '../../lib/cart';
    import { CART_SUCCESS_MESSAGE_DURATION } from '../../lib/constants';

    function setupBookDetailPage() {
      // Metadata toggle
      const metadataToggle = document.getElementById('metadata-toggle');
      const metadataContent = document.querySelector('.metadata-content');
      const metadataArrow = document.querySelector('.metadata-arrow');

      metadataToggle?.addEventListener('click', () => {
        metadataContent?.classList.toggle('hidden');
        metadataArrow?.classList.toggle('open');
      });

      // Author toggle
      const authorToggle = document.getElementById('author-toggle');
      const authorContent = document.querySelector('.author-content');
      const authorArrow = document.querySelector('.author-arrow');

      authorToggle?.addEventListener('click', () => {
        authorContent?.classList.toggle('hidden');
        authorArrow?.classList.toggle('open');
      });

      // Description truncation
      const descriptionText = document.getElementById('description-text');
      const readMoreBtn = document.getElementById('read-more-btn');

      if (descriptionText && readMoreBtn) {
        let isExpanded = false;
        let fullText = descriptionText.innerHTML;

        const checkTruncate = () => {
          const lineHeight = parseFloat(getComputedStyle(descriptionText).lineHeight);
          const maxLines = 8;
          const maxHeight = lineHeight * maxLines;

          if (descriptionText.scrollHeight > maxHeight) {
            if (!isExpanded) {
              descriptionText.style.display = '-webkit-box';
              descriptionText.style.webkitLineClamp = maxLines.toString();
              descriptionText.style.webkitBoxOrient = 'vertical';
              descriptionText.style.overflow = 'hidden';
              readMoreBtn.classList.remove('hidden');
            }
          }
        };

        checkTruncate();

        readMoreBtn.addEventListener('click', () => {
          if (!isExpanded) {
            descriptionText.style.display = 'inline';
            descriptionText.style.webkitLineClamp = 'unset';
            descriptionText.style.webkitBoxOrient = 'unset';
            descriptionText.style.overflow = 'visible';
            readMoreBtn.textContent = '… Read less';
            isExpanded = true;
          } else {
            descriptionText.style.display = '-webkit-box';
            descriptionText.style.webkitLineClamp = '8';
            descriptionText.style.webkitBoxOrient = 'vertical';
            descriptionText.style.overflow = 'hidden';
            readMoreBtn.textContent = '… Read more';
            isExpanded = false;
          }
        });
      }

      const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;

      btn?.addEventListener('click', () => {
        try {
          // Defensive extraction/validation of dataset values to avoid adding malformed items
          const id = btn.dataset.bookId !== undefined ? Number(btn.dataset.bookId) : NaN;
          const title = btn.dataset.bookTitle ?? '';
          const price = btn.dataset.bookPrice !== undefined ? parseInt(btn.dataset.bookPrice) : NaN;

          if (!Number.isFinite(id) || !title || !Number.isFinite(price)) {
            // If data is invalid, skip adding to cart and log a warning.
            console.warn('Invalid add-to-cart dataset — skipping addItem', { id, title, price });
          } else {
            Cart.addItem({
              id,
              title,
              price,
              cover: btn.dataset.bookCover,
              slug: btn.dataset.bookSlug,
              format: btn.dataset.bookFormat,
              language: btn.dataset.bookLanguage,
            });
          }

          const originalText = btn.textContent;
          btn.disabled = true;
          btn.textContent = 'Successfully added';

          setTimeout(() => {
            btn.disabled = false;
            btn.textContent = originalText;
          }, CART_SUCCESS_MESSAGE_DURATION);
        } catch (err) {
          alert((err as Error).message);
        }
      });


      const checkoutBtn = document.getElementById('checkout-btn') as HTMLButtonElement;

      checkoutBtn?.addEventListener('click', () => {
        try {
          // Defensive extraction/validation of dataset values before attempting to add to cart.
          // If the dataset is missing or invalid, skip addItem and still navigate to checkout.
          const id = checkoutBtn.dataset.bookId !== undefined ? Number(checkoutBtn.dataset.bookId) : NaN;
          const title = checkoutBtn.dataset.bookTitle ?? '';
          const price = checkoutBtn.dataset.bookPrice !== undefined ? parseInt(checkoutBtn.dataset.bookPrice) : NaN;

          if (Number.isFinite(id) && title && Number.isFinite(price)) {
            try {
              Cart.addItem({
                id,
                title,
                price,
                cover: checkoutBtn.dataset.bookCover,
                slug: checkoutBtn.dataset.bookSlug,
                format: checkoutBtn.dataset.bookFormat,
                language: checkoutBtn.dataset.bookLanguage,
              });
            } catch (err) {
              // If adding fails for any reason, do not block navigation to checkout.
              console.warn('Failed to add item before checkout — continuing to checkout', err);
            }
          } else {
            console.warn('Checkout button dataset missing or invalid — skipping addItem', { id, title, price });
          }

          window.location.href = '/checkout';
        } catch (err) {
          alert((err as Error).message);
        }
      });

      const readSampleBtn = document.getElementById('read-sample-btn');
      const sampleModal = document.getElementById('sample-modal') as HTMLDivElement;
      const closeModalBtn = document.getElementById('close-modal-btn');
      const modalBackdrop = document.querySelector('.sample-modal-backdrop') as HTMLElement;
      const pageImage = document.getElementById('page-image') as HTMLImageElement;
      const prevBtn = document.getElementById('prev-page-btn') as HTMLButtonElement;
      const nextBtn = document.getElementById('next-page-btn') as HTMLButtonElement;
      const pageSlider = document.getElementById('page-slider') as HTMLInputElement;

      // Get sample pages from data attribute
      // Sample pages are served unoptimized from public/samples/<book-slug>/ to preserve sharpness
      const samplePagesData = readSampleBtn?.getAttribute('data-sample-pages');
      const bookSlug = readSampleBtn?.getAttribute('data-book-slug');
      const samplePagesRaw: string[] = samplePagesData ? JSON.parse(samplePagesData) : [];

      // Build full URLs to unoptimized sample images in public folder
      const samplePages: string[] = samplePagesRaw.map(p => {
        const filename = p.split('/').pop();
        return `/samples/${bookSlug}/${filename}`;
      });
      let currentPageIndex = 0;

      function updateSampleDisplay() {
        if (!pageImage) return;

        // Display current page image (loading="lazy" is set in HTML to preserve sharpness)
        pageImage.src = samplePages[currentPageIndex] || '';
        pageImage.alt = `Book sample page ${currentPageIndex + 1}`;

        // Update button states
        const totalPages = samplePages.length;
        prevBtn.disabled = currentPageIndex === 0;
        nextBtn.disabled = currentPageIndex >= totalPages - 1;

        // Update slider
        pageSlider.value = currentPageIndex.toString();

        // Update page indicator
        const pageIndicator = document.getElementById('page-indicator');
        if (pageIndicator) {
          pageIndicator.textContent = `Page ${currentPageIndex + 1} of ${totalPages}`;
        }
      }

      readSampleBtn?.addEventListener('click', () => {
        if (samplePages.length === 0) return;
        currentPageIndex = 0;
        pageSlider.max = (samplePages.length - 1).toString();
        updateSampleDisplay();
        sampleModal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });

      const closeModal = () => {
        sampleModal?.classList.add("hidden");
        document.body.style.overflow = "";
      };

      closeModalBtn?.addEventListener('click', closeModal);
      modalBackdrop?.addEventListener('click', closeModal);

      prevBtn?.addEventListener('click', () => {
        if (currentPageIndex > 0) {
          currentPageIndex--;
          updateSampleDisplay();
        }
      });

      nextBtn?.addEventListener('click', () => {
        if (currentPageIndex < samplePages.length - 1) {
          currentPageIndex++;
          updateSampleDisplay();
        }
      });

      pageSlider?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        currentPageIndex = parseInt(target.value);
        updateSampleDisplay();
      });


      document.addEventListener('keydown', (e) => {
        if (sampleModal?.classList.contains('hidden')) return;

        if (e.key === 'ArrowLeft' && !prevBtn.disabled) {
          e.preventDefault();
          prevBtn.click();
        } else if (e.key === 'ArrowRight' && !nextBtn.disabled) {
          e.preventDefault();
          nextBtn.click();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          closeModal();
        }
      });
    }

    // Run on initial load and after view transitions
    document.addEventListener('astro:page-load', setupBookDetailPage);
  </script>
</BaseLayout>
