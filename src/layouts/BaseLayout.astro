---
import "../styles/global.css";
import { ViewTransitions } from 'astro:transitions';
const { title = 'Catalog' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <ViewTransitions />
    <!-- Prevent theme flash by setting theme immediately -->
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const initialTheme = savedTheme || 'autumn';
      document.documentElement.setAttribute('data-theme', initialTheme);
    </script>
  </head>
  <body class="min-h-screen bg-base-100 text-base flex flex-col">
    <!-- Sticky navbar -->
    <div class="sticky top-0 z-50">
      <div class="navbar bg-base-100 shadow-sm min-h-0 h-12">
        <div class="flex-1">
          <a href="/" class="btn btn-ghost text-xl mr-4"><img src="/logo.png" alt="Logo" class="h-8" /></a>
          <ul class="menu menu-horizontal px-1">
            <li><a href="/catalog"><span>Books</span></a></li>
            <li><a href="/about"><span>About</span></a></li>
          </ul>
        </div>
        <div class="flex-none flex items-center gap-2">
          <a href="/checkout" class="flex items-center justify-center p-2 rounded-lg hover:bg-transparent transition-colors" aria-label="Shopping cart">
            <div class="indicator">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
              </svg>
              <span id="cart-badge" class="badge badge-sm badge-primary indicator-item hidden">0</span>
            </div>
          </a>

          <button id="theme-toggle" class="flex items-center justify-center p-2 rounded-lg hover:bg-transparent transition-colors cursor-pointer" aria-label="Toggle theme">
            <svg
              id="sun-icon"
              class="fill-current h-5 w-5"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24">
              <path
                d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
            </svg>
            <svg
              id="moon-icon"
              class="fill-current h-5 w-5 hidden"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24">
              <path
                d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Main content; add top margin so content doesn't sit under the sticky navbar -->
    <main class="max-w-7xl mx-auto w-full p-4 mt-6 grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="p-4 bg-base-200 text-base-content">
      <div class="text-right text-sm">
        <a href="/privacy" class="link link-hover">privacy policy</a>
        <span class="mx-2">|</span>
        <span>contact: info@longhousepress.com</span>
        <span class="mx-2">|</span>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="link link-hover">source code</a>
      </div>
    </footer>

    <!-- Theme controller and cart badge updater -->
    <script>
      import { Cart } from '../lib/cart';

      function setupTheme() {
        const themeToggle = document.getElementById('theme-toggle');
        const sunIcon = document.getElementById('sun-icon');
        const moonIcon = document.getElementById('moon-icon');
        const html = document.documentElement;

        if (!themeToggle || !sunIcon || !moonIcon) return;

        function updateThemeIcons(theme: string) {
          if (!sunIcon || !moonIcon) return;

          if (theme === 'dim') {
            sunIcon.classList.add('hidden');
            moonIcon.classList.remove('hidden');
          } else {
            sunIcon.classList.remove('hidden');
            moonIcon.classList.add('hidden');
          }
        }

        const currentTheme = html.getAttribute('data-theme') || 'autumn';
        updateThemeIcons(currentTheme);

        themeToggle.addEventListener('click', () => {
          const current = html.getAttribute('data-theme');
          const newTheme = current === 'dim' ? 'autumn' : 'dim';

          html.setAttribute('data-theme', newTheme);
          updateThemeIcons(newTheme);

          localStorage.setItem('theme', newTheme);
        });
      }

      function setupCart() {
        const badge = document.getElementById('cart-badge');

        function updateCartBadge() {
          if (!badge) return;

          const count = Cart.getCount();

          if (count > 0) {
            badge.textContent = String(count);
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        }

        updateCartBadge();
        window.addEventListener('cart-updated', updateCartBadge);
      }

      function initializeLayout() {
        setupTheme();
        setupCart();
      }

      // Apply theme before the swap to prevent flash
      document.addEventListener('astro:before-swap', (ev) => {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme || 'autumn';
        ev.newDocument.documentElement.setAttribute('data-theme', theme);
      });

      // Run on initial load and after view transitions
      document.addEventListener('astro:page-load', initializeLayout);
    </script>
  </body>
</html>
