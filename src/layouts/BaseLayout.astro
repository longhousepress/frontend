---
import "../styles/global.css";
const { title = 'Catalog' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <!-- Inline script to set theme immediately, preventing flash -->
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const initialTheme = savedTheme || 'autumn';
      document.documentElement.setAttribute('data-theme', initialTheme);
    </script>
  </head>
  <body class="min-h-screen bg-base-100 text-base">
    <!-- Sticky navbar -->
    <div class="sticky top-0 z-50">
      <div class="navbar bg-base-100 shadow-sm min-h-0 h-12">
        <div class="flex-1">
          <a href="/" class="btn btn-ghost text-xl mr-4">DP</a>
          <ul class="menu menu-horizontal px-1">
            <li><a href="/catalog"><span>Books</span></a></li>
            <li><a href="/about"><span>About</span></a></li>
          </ul>
        </div>
        <div class="flex-none flex items-center gap-2">
          <a href="/checkout" class="flex items-center justify-center p-2 rounded-lg hover:bg-transparent transition-colors" aria-label="Shopping cart">
            <div class="indicator">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
                />
              </svg>
              <span id="cart-badge" class="badge badge-sm badge-primary indicator-item hidden">0</span>
            </div>
          </a>
          
          <label class="swap swap-rotate flex items-center justify-center p-2 cursor-pointer hover:bg-transparent transition-colors">
            <input type="checkbox" class="theme-controller hidden" value="dim" />
            <svg
              class="swap-off fill-current"
              style="width: 21px; height: 21px;"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24">
              <path
                d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z" />
            </svg>
            <svg
              class="swap-on fill-current"
              style="width: 21px; height: 21px;"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24">
              <path
                d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z" />
            </svg>
          </label>
        </div>
      </div>
    </div>

    <!-- Main content; add top margin so content doesn't sit under the sticky navbar -->
    <main class="max-w-7xl mx-auto w-full p-4 mt-6">
      <slot />
    </main>

    <!-- Theme controller and cart badge updater -->
    <script>
      import { Cart } from '../lib/cart';

      // Theme controller for autumn/dim theme switching
      const themeToggle = document.querySelector('.theme-controller');
      const html = document.documentElement;

      // Get current theme (already set by inline script in head)
      const currentTheme = html.getAttribute('data-theme');
      
      // Sync toggle state with current theme
      if (themeToggle) {
        (themeToggle as HTMLInputElement).checked = currentTheme === 'dim';
      }

      // Handle toggle changes
      themeToggle?.addEventListener('change', (e) => {
        const newTheme = (e.target as HTMLInputElement).checked ? 'dim' : 'autumn';
        html.setAttribute('data-theme', newTheme);
        
        // Only persist dark theme choice, clear storage when switching back to autumn
        if (newTheme === 'dim') {
          localStorage.setItem('theme', newTheme);
        } else {
          localStorage.removeItem('theme');
        }
      });

      // Cart badge updater
      const badge = document.getElementById('cart-badge');

      function updateCartBadge() {
        if (!badge) return;
        
        const count = Cart.getCount();
        
        if (count > 0) {
          badge.textContent = String(count);
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      }

      // Initial update
      updateCartBadge();

      // Listen for cart updates
      window.addEventListener('cart-updated', updateCartBadge);
    </script>
  </body>
</html>
